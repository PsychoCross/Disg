        Parent=Main,Position=UDim2.new(0,0,0,52),Size=UDim2.new(0,130,1,-52),
        BackgroundColor3=Theme.Surface,BorderSizePixel=0,
        ScrollBarThickness=2,ScrollBarImageColor3=Theme.Accent,
