            -- DIVIDER
            function Section:AddDivider()
                local row=MakeRow(10)
                Create("Frame",{Parent=row,Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0.5,0),BackgroundColor3=Theme.Border,BorderSizePixel=0,ZIndex=4})
