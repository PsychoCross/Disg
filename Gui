                    task.delay(0.5,function() r:Destroy() end)
                end
                Btn.MouseEnter:Connect(function() Tween(Btn,{BackgroundColor3=Theme.SurfaceAlt},0.15); Tween(bS,{Color=Theme.Accent},0.15) end)
                Btn.MouseLeave:Connect(function() Tween(Btn,{BackgroundColor3=Theme.Surface},0.15); Tween(bS,{Color=Theme.Border},0.15) end)
                Btn.MouseButton1Click:Connect(function()
                    local mp=UserInputService:GetMouseLocation(); Ripple(mp.X,mp.Y)
                    Tween(Btn,{BackgroundColor3=Theme.Accent},0.1)
                    task.delay(0.12,function() Tween(Btn,{BackgroundColor3=Theme.SurfaceAlt},0.15) end)
                    cb()
                end)
                return Btn
            end

