    AddCorner(Grad,14)
    Create("UIGradient",{Parent=Grad,
        Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(80,20,140)),ColorSequenceKeypoint.new(1,Color3.fromRGB(8,6,12))}),
        Rotation=135,
        Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.7),NumberSequenceKeypoint.new(1,1)}),
    })

    -- Tab bar
