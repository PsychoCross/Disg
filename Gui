        guiConn:Disconnect()
        Tween(Main,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},0.3,Enum.EasingStyle.Back,Enum.EasingDirection.In)
        if blur then Tween(blur,{Size=0},0.4) end
        task.delay(0.35,function() ScreenGui:Destroy() end)
    end)

    local minimized=false
    local MinBtn=MakeTopBtn(-70,"-",Theme.TextSecondary)
    MinBtn.MouseButton1Click:Connect(function()
        minimized=not minimized
        if minimized then
            TabBar.Visible=false; ContentHolder.Visible=false; Separator.Visible=false; TopBarSquare.Visible=false
            Tween(Main,{Size=UDim2.new(0,180,0,52)},0.25)
            MinBtn.Text="+"; MinBtn.TextColor3=Theme.Accent
        else
            TopBarSquare.Visible=true
            MinBtn.Text="-"; MinBtn.TextColor3=Theme.TextSecondary
            Tween(Main,{Size=Size},0.3,Enum.EasingStyle.Back)
            task.delay(0.28,function()
                if not minimized then TabBar.Visible=true; ContentHolder.Visible=true; Separator.Visible=true end
            end)
        end
    end)

    MakeDraggable(Main,TopBar)

    local Window={_tabs={},_activeTab=nil,_registry=_registry,_hubName=HubName}

    -- SaveConfig / LoadConfig
    function Window:SaveConfig(name)
        name=name or "default"
        local data={}
        for k,e in pairs(_registry) do pcall(function() data[k]=e.Get() end) end
        EnsureFolder(HubName); EnsureFolder(HubName.."/configs")
        if writefile then
            writefile(HubName.."/configs/"..name..".json",JSONEncode(data))
            Window:Notify("Config",'Saved "'..name..'"',"success",2.5)
        end
    end
    function Window:LoadConfig(name)
        name=name or "default"
        local path=HubName.."/configs/"..name..".json"
        if not (readfile and isfile and isfile(path)) then Window:Notify("Config","Not found","error",2.5) return end
        local ok,raw=pcall(readfile,path)
        if not ok then Window:Notify("Config","Read failed","error",2.5) return end
        for k,v in pairs(JSONDecode(raw)) do if _registry[k] then pcall(_registry[k].Set,v) end end
        Window:Notify("Config",'Loaded "'..name..'"',"success",2.5)
    end
    function Window:ListConfigs()
        local path=HubName.."/configs"
        if not (listfiles and isfolder and isfolder(path)) then return {} end
        local out={}
        for _,f in ipairs(listfiles(path)) do
            local n=f:match("([^/\\]+)%.json$"); if n then table.insert(out,n) end
        end
        return out
    end

