            table.insert(tabData._sections,Section)
            return Section
        end
        return tabData
    end

    -- NOTIFY
    function Window:Notify(title,message,ntype,duration)
        ntype=ntype or "info"; duration=duration or 3
        local colors={info=Theme.Accent,success=Theme.Success,warning=Theme.Warning,error=Theme.Danger}
        local icons={info="‚ĄĻ",success="‚úď",warning="‚ö†",error="‚úē"}
        local col=colors[ntype] or Theme.Accent
        local NH=ScreenGui:FindFirstChild("NotifHolder") or Create("Frame",{Name="NotifHolder",Parent=ScreenGui,Position=UDim2.new(1,-270,1,-300),Size=UDim2.new(0,250,0,280),BackgroundTransparency=1})
        if not NH.Parent then NH.Parent=ScreenGui end
        NH:FindFirstChildOfClass("UIListLayout") or Create("UIListLayout",{Parent=NH,VerticalAlignment=Enum.VerticalAlignment.Bottom,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6)})
        local NF=Create("Frame",{Parent=NH,Size=UDim2.new(1,0,0,0),BackgroundColor3=Theme.Surface,ClipsDescendants=true,ZIndex=99})
        AddCorner(NF,10); AddStroke(NF,col,1.5)
        local ac=Create("Frame",{Parent=NF,Size=UDim2.new(0,3,1,0),BackgroundColor3=col,ZIndex=100})
        Create("UICorner",{Parent=ac,CornerRadius=UDim.new(0,3)})
        Create("TextLabel",{Parent=NF,Position=UDim2.new(0,14,0,6),Size=UDim2.new(1,-20,0,18),BackgroundTransparency=1,Text=(icons[ntype] or "").."  "..title,TextColor3=col,Font=Enum.Font.GothamBold,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=100})
        Create("TextLabel",{Parent=NF,Position=UDim2.new(0,14,0,24),Size=UDim2.new(1,-20,0,30),BackgroundTransparency=1,Text=message,TextColor3=Theme.TextSecondary,Font=Enum.Font.Gotham,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,ZIndex=100})
        local Prog=Create("Frame",{Parent=NF,Position=UDim2.new(0,0,1,-2),Size=UDim2.new(1,0,0,2),BackgroundColor3=col,ZIndex=101})
        Tween(NF,{Size=UDim2.new(1,0,0,60)},0.3,Enum.EasingStyle.Back)
        Tween(Prog,{Size=UDim2.new(0,0,0,2)},duration,Enum.EasingStyle.Linear)
        task.delay(duration,function() Tween(NF,{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0)},0.3); task.delay(0.35,function() NF:Destroy() end) end)
    end

    task.delay(0.6,function() Window:Notify("ACTED","Was loaded successfully.","success",3) end)
    return Window
end

return ACTED
