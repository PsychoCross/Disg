            end

            -- SLIDER
            function Section:AddSlider(label,min,max,default,cb,key)
                min=min or 0; max=max or 100; default=math.clamp(default or min,min,max); cb=cb or function()end
                local value=default; local row=MakeRow(52)
                local LR=Create("Frame",{Parent=row,Size=UDim2.new(1,0,0,20),BackgroundTransparency=1,ZIndex=4})
                Create("TextLabel",{Parent=LR,Size=UDim2.new(0.7,0,1,0),BackgroundTransparency=1,Text=label,TextColor3=Theme.TextPrimary,Font=Enum.Font.Gotham,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4})
                local VL=Create("TextLabel",{Parent=LR,Position=UDim2.new(0.7,0,0,0),Size=UDim2.new(0.3,0,1,0),BackgroundTransparency=1,Text=tostring(default),TextColor3=Theme.Accent,Font=Enum.Font.GothamBold,TextSize=13,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=4})
                local Track=Create("Frame",{Parent=row,Position=UDim2.new(0,0,0,28),Size=UDim2.new(1,0,0,8),BackgroundColor3=Theme.ToggleOff,ZIndex=4})
                AddCorner(Track,999); AddStroke(Track,Theme.Border,1)
                local Fill=Create("Frame",{Parent=Track,Size=UDim2.new((default-min)/(max-min),0,1,0),BackgroundColor3=Theme.SliderFill,ZIndex=5})
                AddCorner(Fill,999)
                Create("UIGradient",{Parent=Fill,Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Theme.Accent),ColorSequenceKeypoint.new(1,Theme.AccentGlow)})})
                local Thumb=Create("Frame",{Parent=Track,Size=UDim2.new(0,14,0,14),Position=UDim2.new((default-min)/(max-min),0-7,0.5,-7),BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=6})
                AddCorner(Thumb,999); AddStroke(Thumb,Theme.Accent,1.5)
                local SBtn=Create("TextButton",{Parent=Track,Size=UDim2.new(1,0,0,24),Position=UDim2.new(0,0,0.5,-12),BackgroundTransparency=1,Text="",ZIndex=7})
                local sliding=false
                local function Upd(x)
                    local rel=math.clamp((x-Track.AbsolutePosition.X)/Track.AbsoluteSize.X,0,1)
                    value=math.floor(min+rel*(max-min)); VL.Text=tostring(value)
                    Tween(Fill,{Size=UDim2.new(rel,0,1,0)},0.05)
                    Tween(Thumb,{Position=UDim2.new(rel,0-7,0.5,-7)},0.05); cb(value)
                end
                SBtn.MouseButton1Down:Connect(function() sliding=true; Upd(UserInputService:GetMouseLocation().X) end)
                UserInputService.InputChanged:Connect(function(i)
                    if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then Upd(i.Position.X) end
                end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sliding=false end
                end)
                local obj={Get=function() return value end,Set=function(v) v=math.clamp(v,min,max); Upd(Track.AbsolutePosition.X+((v-min)/(max-min))*Track.AbsoluteSize.X) end}
                if key then _registry[key]={Get=obj.Get,Set=function(v) obj.Set(tonumber(v) or value) end} end
                return obj
            end

            -- TEXTBOX
            function Section:AddTextbox(label,ph,default,cb,key)
                cb=cb or function()end; local row=MakeRow(54)
                Create("TextLabel",{Parent=row,Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Text=label,TextColor3=Theme.TextPrimary,Font=Enum.Font.Gotham,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4})
                local BF=Create("Frame",{Parent=row,Position=UDim2.new(0,0,0,22),Size=UDim2.new(1,0,0,28),BackgroundColor3=Theme.Background,ZIndex=4})
                AddCorner(BF,7); local bxS=AddStroke(BF,Theme.Border,1.2)
                local Box=Create("TextBox",{Parent=BF,Size=UDim2.new(1,-10,1,0),Position=UDim2.new(0,6,0,0),BackgroundTransparency=1,Text=default or "",PlaceholderText=ph or "Enter text...",TextColor3=Theme.TextPrimary,PlaceholderColor3=Theme.TextDim,Font=Enum.Font.Gotham,TextSize=12,ClearTextOnFocus=false,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5})
                Box.Focused:Connect(function() Tween(bxS,{Color=Theme.Accent},0.2); Tween(BF,{BackgroundColor3=Theme.SurfaceAlt},0.2) end)
                Box.FocusLost:Connect(function(e) Tween(bxS,{Color=Theme.Border},0.2); Tween(BF,{BackgroundColor3=Theme.Background},0.2); if e then cb(Box.Text) end end)
