    -- Top bar
    local TopBar=Create("Frame",{Parent=Main,Size=UDim2.new(1,0,0,52),BackgroundColor3=Theme.Surface,ZIndex=10})
    AddCorner(TopBar,14)
    local TopBarSquare=Create("Frame",{Parent=TopBar,Size=UDim2.new(1,0,0.5,0),Position=UDim2.new(0,0,0.5,0),BackgroundColor3=Theme.Surface,BorderSizePixel=0,ZIndex=9})

