            Tween(Page,{Position=UDim2.new(0,0,0,0)},0.2,Enum.EasingStyle.Quart)
        end
        TabBtn.MouseButton1Click:Connect(Activate)
        tabData._btn=TabBtn; tabData._page=Page; tabData._stroke=tabStroke
        table.insert(Window._tabs,tabData)
        if #Window._tabs==1 then Activate() end

