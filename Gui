            -- ============================================================
            -- DROPDOWN ‚ÄĒ fix real: lista in Main (nu ContentHolder),
            -- pozitionata in coordonate absolute ale ecranului relative la Main
            -- Flip sus/jos bazat pe spatiul ramas in Main
            -- ============================================================
            function Section:AddDropdown(label,options,default,cb,key)
                cb=cb or function()end; options=options or {}
                local selected=default or options[1] or ""; local open=false
                local row=MakeRow(34)

                Create("TextLabel",{Parent=row,Size=UDim2.new(0.5,0,1,0),BackgroundTransparency=1,Text=label,TextColor3=Theme.TextPrimary,Font=Enum.Font.Gotham,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4})
                local DDBtn=Create("TextButton",{Parent=row,Position=UDim2.new(0.45,0,0.1,0),Size=UDim2.new(0.55,0,0.8,0),BackgroundColor3=Theme.Surface,Text=selected.." ‚Ėĺ",TextColor3=Theme.TextPrimary,Font=Enum.Font.Gotham,TextSize=12,AutoButtonColor=false,ZIndex=4})
                AddCorner(DDBtn,7); local ddS=AddStroke(DDBtn,Theme.Border,1)

                -- Lista parenta in MAIN (nu ContentHolder) ca sa nu fie clipata
                -- ZIndex mare ca sa fie deasupra totul
                local ITEM_H=28; local MAX_H=150; local PAD=8

                local DDList=Create("Frame",{
                    Parent=Main,  -- CHEIE: parent=Main, nu ContentHolder
                    Size=UDim2.new(0,0,0,0),
                    BackgroundColor3=Theme.SurfaceAlt,
                    Visible=false,ZIndex=50,ClipsDescendants=true,
                })
                AddCorner(DDList,8); AddStroke(DDList,Theme.Accent,1.2)
                Create("UIListLayout",{Parent=DDList,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2)})
                AddPadding(DDList,4,4,4,4)

                local ddW=0 -- latimea reala, calculata la open

                local function CloseDD()
                    if not open then return end; open=false
                    Tween(DDList,{Size=UDim2.new(0,ddW,0,0)},0.18,Enum.EasingStyle.Quart)
                    DDBtn.Text=selected.." ‚Ėĺ"
                    task.delay(0.2,function() DDList.Visible=false end)
                end

                local function OpenDD()
                    open=true
                    local targetH=math.min(#options*ITEM_H+PAD,MAX_H)
                    ddW=DDBtn.AbsoluteSize.X

                    -- Pozitie absoluta a butonului pe ecran
                    local btnAbsX=DDBtn.AbsolutePosition.X
                    local btnAbsY=DDBtn.AbsolutePosition.Y
                    local btnH=DDBtn.AbsoluteSize.Y

                    -- Pozitie relativa fata de Main (parent-ul DDList)
                    local mainAbsX=Main.AbsolutePosition.X
                    local mainAbsY=Main.AbsolutePosition.Y
                    local mainH=Main.AbsoluteSize.Y

                    local relX=btnAbsX-mainAbsX
                    local relY=btnAbsY-mainAbsY

                    -- Spatiu disponibil sub buton in interiorul Main
                    local spaceBelow=mainH-(relY+btnH)
                    -- DacńÉ nu incape jos, deschidem sus
                    local listY
                    if spaceBelow<targetH and relY>=targetH then
                        -- deschide sus
                        listY=relY-targetH-2
                        DDBtn.Text=selected.." ‚Ėī"
                    else
                        -- deschide jos
                        listY=relY+btnH+2
                        DDBtn.Text=selected.." ‚Ėī"
                    end

                    DDList.Size=UDim2.new(0,ddW,0,0)
                    DDList.Position=UDim2.new(0,relX,0,listY)
                    DDList.Visible=true
                    Tween(DDList,{Size=UDim2.new(0,ddW,0,targetH)},0.2,Enum.EasingStyle.Back)
                end

                for _,opt in ipairs(options) do
                    local O=Create("TextButton",{Parent=DDList,Size=UDim2.new(1,0,0,ITEM_H-2),BackgroundColor3=Theme.Surface,Text=opt,TextColor3=(opt==selected) and Theme.Accent or Theme.TextPrimary,Font=Enum.Font.Gotham,TextSize=12,AutoButtonColor=false,ZIndex=51})
                    AddCorner(O,6)
                    O.MouseEnter:Connect(function() Tween(O,{BackgroundColor3=Theme.SurfaceAlt},0.1) end)
                    O.MouseLeave:Connect(function() Tween(O,{BackgroundColor3=Theme.Surface},0.1) end)
                    O.MouseButton1Click:Connect(function()
                        selected=opt; DDBtn.Text=selected.." ‚Ėĺ"
                        for _,c in ipairs(DDList:GetChildren()) do if c:IsA("TextButton") then c.TextColor3=(c.Text==selected) and Theme.Accent or Theme.TextPrimary end end
                        CloseDD(); cb(selected)
                    end)
                end

                DDBtn.MouseButton1Click:Connect(function() if open then CloseDD() else OpenDD() end end)
                DDBtn.MouseEnter:Connect(function() Tween(ddS,{Color=Theme.Accent},0.15) end)
                DDBtn.MouseLeave:Connect(function() Tween(ddS,{Color=Theme.Border},0.15) end)

                -- Inchide dropdown cand userul da click in alta parte
                UserInputService.InputBegan:Connect(function(i)
                    if open and (i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch) then
                        task.wait()
                        if open then CloseDD() end
                    end
                end)

                local obj={Get=function() return selected end,Set=function(v) selected=v; DDBtn.Text=v.." ‚Ėĺ"; cb(v) end}
                if key then _registry[key]={Get=obj.Get,Set=obj.Set} end
                return obj
            end

            -- COLORPICKER
            function Section:AddColorPicker(label,default,cb)
                cb=cb or function()end; default=default or Color3.fromRGB(140,60,220)
                local row=MakeRow(34)
                Create("TextLabel",{Parent=row,Size=UDim2.new(0.7,0,1,0),BackgroundTransparency=1,Text=label,TextColor3=Theme.TextPrimary,Font=Enum.Font.Gotham,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4})
                local Sw=Create("Frame",{Parent=row,Position=UDim2.new(1,-36,0.15,0),Size=UDim2.new(0,30,0.7,0),BackgroundColor3=default,ZIndex=4})
                AddCorner(Sw,6); AddStroke(Sw,Theme.Border,1)
                local hue,sat,val=Color3.toHSV(default); local CPOpen=false
                local CPF=Create("Frame",{Parent=Main,Size=UDim2.new(0,160,0,0),BackgroundColor3=Theme.Surface,Visible=false,ZIndex=45,ClipsDescendants=true})
                AddCorner(CPF,10); AddStroke(CPF,Theme.Accent,1.2)
                local HT=Create("Frame",{Parent=CPF,Position=UDim2.new(0,8,0,10),Size=UDim2.new(1,-16,0,14),BackgroundColor3=Color3.fromRGB(200,200,200),ZIndex=46})
                AddCorner(HT,999)
                Create("UIGradient",{Parent=HT,Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromHSV(0,1,1)),ColorSequenceKeypoint.new(1/6,Color3.fromHSV(1/6,1,1)),ColorSequenceKeypoint.new(2/6,Color3.fromHSV(2/6,1,1)),ColorSequenceKeypoint.new(3/6,Color3.fromHSV(3/6,1,1)),ColorSequenceKeypoint.new(4/6,Color3.fromHSV(4/6,1,1)),ColorSequenceKeypoint.new(5/6,Color3.fromHSV(5/6,1,1)),ColorSequenceKeypoint.new(1,Color3.fromHSV(1,1,1))})})
                local HTh=Create("Frame",{Parent=HT,Size=UDim2.new(0,10,0,18),Position=UDim2.new(hue,0-5,0.5,-9),BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=47})
                AddCorner(HTh,999)
                local function UpdCP() local c=Color3.fromHSV(hue,sat,val); Sw.BackgroundColor3=c; HTh.Position=UDim2.new(hue,0-5,0.5,-9); cb(c) end
                local hSl=false
                Create("TextButton",{Parent=HT,Size=UDim2.new(1,0,0,24),Position=UDim2.new(0,0,0.5,-12),BackgroundTransparency=1,Text="",ZIndex=48}).MouseButton1Down:Connect(function() hSl=true end)
                UserInputService.InputChanged:Connect(function(i)
                    if hSl and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                        hue=math.clamp((i.Position.X-HT.AbsolutePosition.X)/HT.AbsoluteSize.X,0,1); UpdCP()
                    end
                end)
                UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then hSl=false end end)
                Create("TextButton",{Parent=row,Size=UDim2.new(0,34,1,0),Position=UDim2.new(1,-36,0,0),BackgroundTransparency=1,Text="",ZIndex=5}).MouseButton1Click:Connect(function()
                    CPOpen=not CPOpen
                    local ap=Sw.AbsolutePosition-Main.AbsolutePosition
                    CPF.Position=UDim2.new(0,ap.X-120,0,ap.Y+26)
                    CPF.Visible=true
                    Tween(CPF,{Size=UDim2.new(0,160,0,CPOpen and 56 or 0)},0.2,Enum.EasingStyle.Back)
                    if not CPOpen then task.delay(0.22,function() CPF.Visible=false end) end
                end)
                UpdCP()
                return {Get=function() return Color3.fromHSV(hue,sat,val) end}
            end

            -- LABEL
            function Section:AddLabel(text,col)
                local row=MakeRow(22)
                Create("TextLabel",{Parent=row,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=text,TextColor3=col or Theme.TextSecondary,Font=Enum.Font.Gotham,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4,TextWrapped=true})
