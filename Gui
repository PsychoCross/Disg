            function Section:AddDropdown(label, options, default, callback)
                callback = callback or function() end
                options = options or {}
                local selected = default or options[1] or ""
                local open = false

                local row = MakeRow(34)

                Create("TextLabel",{
                    Parent=row,Size=UDim2.new(0.5,0,1,0),
                    BackgroundTransparency=1,Text=label,
                    TextColor3=Theme.TextPrimary,Font=Enum.Font.Gotham,TextSize=13,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4,
                })

                local DDBtn = Create("TextButton",{
                    Parent=row,
                    Position=UDim2.new(0.45,0,0.1,0),
                    Size=UDim2.new(0.55,0,0.8,0),
                    BackgroundColor3=Theme.Surface,
                    Text=selected.." ‚Ėĺ",
                    TextColor3=Theme.TextPrimary,
                    Font=Enum.Font.Gotham,TextSize=12,
                    AutoButtonColor=false,ZIndex=4,
                })
                AddCorner(DDBtn,7)
                local ddStroke=AddStroke(DDBtn,Theme.Border,1)

                -- Dropdown list (rendered in ContentHolder to avoid clipping)
                local DDList = Create("Frame",{
                    Parent=ContentHolder,
                    Size=UDim2.new(0,DDBtn.AbsoluteSize.X,0,0),
                    BackgroundColor3=Theme.SurfaceAlt,
                    Visible=false,
                    ZIndex=20,
                    ClipsDescendants=true,
                })
                AddCorner(DDList,8)
                AddStroke(DDList,Theme.Accent,1.2)
                local DLayout=Create("UIListLayout",{Parent=DDList,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2)})
                AddPadding(DDList,4,4,4,4)

                local function CloseDD()
                    open=false
                    Tween(DDList,{Size=UDim2.new(0,DDBtn.AbsoluteSize.X,0,0)},0.2,Enum.EasingStyle.Quart)
                    DDBtn.Text=selected.." ‚Ėĺ"
                    task.delay(0.22,function() DDList.Visible=false end)
                end

                local function OpenDD()
                    open=true
                    local absPos = DDBtn.AbsolutePosition
                    local relPos = absPos - ContentHolder.AbsolutePosition
                    DDList.Position = UDim2.new(0,relPos.X,0,relPos.Y+DDBtn.AbsoluteSize.Y+4)
                    DDList.Size = UDim2.new(0,DDBtn.AbsoluteSize.X,0,0)
                    DDList.Visible=true
                    local targetH = math.min(#options*30+8, 160)
                    Tween(DDList,{Size=UDim2.new(0,DDBtn.AbsoluteSize.X,0,targetH)},0.2,Enum.EasingStyle.Back)
                    DDBtn.Text=selected.." ‚Ėī"
                end

                for _, opt in ipairs(options) do
                    local OptBtn = Create("TextButton",{
                        Parent=DDList,
                        Size=UDim2.new(1,0,0,26),
                        BackgroundColor3=Theme.Surface,
                        Text=opt,
                        TextColor3=(opt==selected) and Theme.Accent or Theme.TextPrimary,
                        Font=Enum.Font.Gotham,TextSize=12,
                        AutoButtonColor=false,ZIndex=21,
                    })
                    AddCorner(OptBtn,6)
                    OptBtn.MouseEnter:Connect(function()
                        Tween(OptBtn,{BackgroundColor3=Theme.SurfaceAlt},0.1)
                    end)
                    OptBtn.MouseLeave:Connect(function()
                        Tween(OptBtn,{BackgroundColor3=Theme.Surface},0.1)
                    end)
                    OptBtn.MouseButton1Click:Connect(function()
                        selected=opt
                        DDBtn.Text=selected.." ‚Ėĺ"
                        for _, c in ipairs(DDList:GetChildren()) do
                            if c:IsA("TextButton") then
                                c.TextColor3=(c.Text==selected) and Theme.Accent or Theme.TextPrimary
                            end
                        end
                        CloseDD()
                        callback(selected)
                    end)
                end

                DDBtn.MouseButton1Click:Connect(function()
                    if open then CloseDD() else OpenDD() end
                end)
                DDBtn.MouseEnter:Connect(function()
                    Tween(ddStroke,{Color=Theme.Accent},0.15)
                end)
                DDBtn.MouseLeave:Connect(function()
                    Tween(ddStroke,{Color=Theme.Border},0.15)
                end)

                return {
                    Value=selected,
                    Set=function(v)
                        selected=v
                        DDBtn.Text=v.." ‚Ėĺ"
                        callback(v)
                    end,
                    Get=function() return selected end
                }
            end

