-- ============================================================
-- Config slot management helpers
-- Slots are stored as ACTED_config_<slotName>.json
-- We keep a known-slots list in ACTED_slots.json
-- ============================================================
local CONFIG_PREFIX = "ACTED_config_"
local SLOTS_FILE    = "ACTED_slots.json"

local function SlotFileName(slotName)
    return CONFIG_PREFIX .. slotName .. ".json"
end

local function ReadSlotList()
    local ok, raw = pcall(readfile, SLOTS_FILE)
    if not ok or not raw then return {} end
    local ok2, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(raw)
    end)
    if ok2 and type(data) == "table" then return data end
    return {}
end

local function WriteSlotList(list)
    local ok, json = pcall(function()
        return game:GetService("HttpService"):JSONEncode(list)
    end)
    if ok then pcall(writefile, SLOTS_FILE, json) end
end

local function AddSlotToList(slotName)
    local list = ReadSlotList()
    for _, v in ipairs(list) do
        if v == slotName then return end   -- already exists
    end
    table.insert(list, slotName)
    WriteSlotList(list)
end

local function RemoveSlotFromList(slotName)
    local list = ReadSlotList()
    local newList = {}
    for _, v in ipairs(list) do
        if v ~= slotName then table.insert(newList, v) end
    end
    WriteSlotList(newList)
end

