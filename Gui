                local HueDrag = Create("TextButton", {
                    Parent = HueTrack, Size = UDim2.new(1, 0, 0, 24),
                    Position = UDim2.new(0, 0, 0.5, -12), BackgroundTransparency = 1, Text = "", ZIndex = 53,
                })
                HueDrag.MouseButton1Down:Connect(function() hSliding = true end)
                UserInputService.InputChanged:Connect(function(inp)
                    if hSliding and (inp.UserInputType == Enum.UserInputType.MouseMovement
                                  or inp.UserInputType == Enum.UserInputType.Touch) then
                        hue = math.clamp((inp.Position.X - HueTrack.AbsolutePosition.X) / HueTrack.AbsoluteSize.X, 0, 1)
                        UpdateColor()
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then hSliding = false end
                end)

                local SwatchBtn = Create("TextButton", {
                    Parent = row, Size = UDim2.new(0, 34, 1, 0),
                    Position = UDim2.new(1, -36, 0, 0),
                    BackgroundTransparency = 1, Text = "", ZIndex = 5,
                })
                SwatchBtn.MouseButton1Click:Connect(function()
                    CPOpen = not CPOpen
                    local absPos = Swatch.AbsolutePosition
                    CPFrame.Position = UDim2.new(0, absPos.X - 120, 0, absPos.Y + 26)
                    CPFrame.Visible = true
                    Tween(CPFrame, {Size = UDim2.new(0, 160, 0, CPOpen and 56 or 0)}, 0.2, Enum.EasingStyle.Back)
                    if not CPOpen then task.delay(0.22, function() CPFrame.Visible = false end) end
                end)

                UpdateColor()

                local function GetColor() return Color3.fromHSV(hue, sat, val_cp) end
                local obj = {Get = GetColor}
                if configKey then
                    table.insert(Window._elements, {key = configKey,
                        get = function()
                            local c = GetColor()
                            return {r = c.R, g = c.G, b = c.B}
                        end,
                        set = function(v)
                            if type(v) == "table" then
                                local col = Color3.new(v.r, v.g, v.b)
                                hue, sat, val_cp = Color3.toHSV(col)
                                UpdateColor()
                            end
                        end})
                end
                return obj
            end

            -- ==========================
            -- LABEL
            -- ==========================
            function Section:AddLabel(text, color)
                local row = MakeRow(22)
                Create("TextLabel", {
                    Parent = row, Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1, Text = text,
                    TextColor3 = color or Theme.TextSecondary,
                    Font = Enum.Font.Gotham, TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 4, TextWrapped = true,
                })
            end

            -- ==========================
            -- KEYBIND
            -- ==========================
            function Section:AddKeybind(label, default, callback, configKey)
                callback = callback or function() end
                default  = default  or Enum.KeyCode.RightShift
                local key = default
                local listening = false
                local row = MakeRow(34)
                Create("TextLabel", {
                    Parent = row, Size = UDim2.new(0.6, 0, 1, 0),
                    BackgroundTransparency = 1, Text = label,
                    TextColor3 = Theme.TextPrimary, Font = Enum.Font.Gotham, TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
                })
                local KBtn = Create("TextButton", {
                    Parent = row, Position = UDim2.new(0.62, 0, 0.1, 0),
                    Size = UDim2.new(0.38, 0, 0.8, 0),
                    BackgroundColor3 = Theme.Surface,
                    Text = "[" .. tostring(key.Name) .. "]",
                    TextColor3 = Theme.Accent, Font = Enum.Font.GothamSemibold, TextSize = 11,
                    AutoButtonColor = false, ZIndex = 4,
                })
                AddCorner(KBtn, 7)
                AddStroke(KBtn, Theme.Border, 1)
                KBtn.MouseButton1Click:Connect(function()
                    listening = true
                    KBtn.Text = "[...]"
                    KBtn.TextColor3 = Theme.Warning
                end)
                UserInputService.InputBegan:Connect(function(inp)
                    if listening and inp.UserInputType == Enum.UserInputType.Keyboard then
                        key = inp.KeyCode
                        KBtn.Text = "[" .. tostring(key.Name) .. "]"
                        KBtn.TextColor3 = Theme.Accent
                        listening = false
                    end
                    if not listening and inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == key then
                        callback(key)
                    end
                end)
                local obj = {Get = function() return key end}
                if configKey then
                    table.insert(Window._elements, {key = configKey,
                        get = function() return key.Name end,
                        set = function(v)
                            local ok, kc = pcall(function() return Enum.KeyCode[v] end)
                            if ok and kc then key = kc; KBtn.Text = "[" .. v .. "]" end
                        end})
                end
                return obj
            end

            -- ==========================
            -- DIVIDER
            -- ==========================
            function Section:AddDivider()
                local row = MakeRow(10)
                Create("Frame", {
                    Parent = row, Size = UDim2.new(1, 0, 0, 1),
                    Position = UDim2.new(0, 0, 0.5, 0),
                    BackgroundColor3 = Theme.Border, BorderSizePixel = 0, ZIndex = 4,
                })
            end

            table.insert(tabData._sections, Section)
            return Section
        end -- CreateSection

        return tabData
    end -- CreateTab

    -- ============================================================
    -- Notifications
    -- ============================================================
    function Window:Notify(title, message, ntype, duration)
        ntype    = ntype    or "info"
        duration = duration or 3
        local colors = {info = Theme.Accent, success = Theme.Success, warning = Theme.Warning, error = Theme.Danger}
        local col = colors[ntype] or Theme.Accent

        local NHolder = ScreenGui:FindFirstChild("NotifHolder") or Create("Frame", {
            Name = "NotifHolder", Parent = ScreenGui,
            Position = UDim2.new(1, -270, 1, -300),
            Size = UDim2.new(0, 250, 0, 280),
            BackgroundTransparency = 1,
        })
        if not NHolder.Parent then NHolder.Parent = ScreenGui end
        local _ = NHolder:FindFirstChildOfClass("UIListLayout") or Create("UIListLayout", {
            Parent = NHolder, VerticalAlignment = Enum.VerticalAlignment.Bottom,
            SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6),
        })

        local NFrame = Create("Frame", {
            Parent = NHolder, Size = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = Theme.Surface,
            ClipsDescendants = true, ZIndex = 99,
        })
        AddCorner(NFrame, 10)
        AddStroke(NFrame, col, 1.5)
        local accent = Create("Frame", {Parent = NFrame, Size = UDim2.new(0, 3, 1, 0), BackgroundColor3 = col, ZIndex = 100})
        Create("UICorner", {Parent = accent, CornerRadius = UDim.new(0, 3)})
        Create("TextLabel", {
            Parent = NFrame, Position = UDim2.new(0, 14, 0, 6), Size = UDim2.new(1, -20, 0, 18),
            BackgroundTransparency = 1, Text = title,
            TextColor3 = col, Font = Enum.Font.GothamBold, TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 100,
        })
        Create("TextLabel", {
            Parent = NFrame, Position = UDim2.new(0, 14, 0, 24), Size = UDim2.new(1, -20, 0, 30),
            BackgroundTransparency = 1, Text = message,
            TextColor3 = Theme.TextSecondary, Font = Enum.Font.Gotham, TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true, ZIndex = 100,
        })
        local Prog = Create("Frame", {
            Parent = NFrame, Position = UDim2.new(0, 0, 1, -2),
            Size = UDim2.new(1, 0, 0, 2), BackgroundColor3 = col, ZIndex = 101,
        })
        Tween(NFrame, {Size = UDim2.new(1, 0, 0, 60)}, 0.3, Enum.EasingStyle.Back)
        Tween(Prog, {Size = UDim2.new(0, 0, 0, 2)}, duration, Enum.EasingStyle.Linear)
        task.delay(duration, function()
            Tween(NFrame, {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0)}, 0.3)
            task.delay(0.35, function() NFrame:Destroy() end)
        end)
    end

    task.delay(0.6, function()
        Window:Notify("ACTED", "Was loaded successfully.", "success", 3)
    end)

    return Window
end

return ACTED

--[[
========================================
CHANGELOG v2.2
========================================

NEW: MULTI-SLOT CONFIG MANAGER
  Call Window:AddConfigManager(section) inside any section to embed a full
  config management panel. No emojis, English only.

  Panel contains:
    - Slot name textbox       (type a new name to create a slot)
    - Select slot dropdown    (lists all existing saved slots; auto-refreshed)
    - Save to slot button     (saves current values to typed name or selected slot)
    - Load selected slot button
    - Delete selected slot button
    - Refresh slot list button (re-reads ACTED_slots.json from disk)

  Slots are tracked in ACTED_slots.json so the dropdown always knows what
  exists without scanning the filesystem.

  Example usage:
    local configTab     = Window:CreateTab("Config")
    local configSection = configTab:CreateSection("Config Manager")
    Window:AddConfigManager(configSection)

  Existing AddButton save/load approach still works:
    section:AddButton("Save", function() Window:SaveConfig("slot1") end)
    section:AddButton("Load", function() Window:LoadConfig("slot1") end)

NEW: Dropdown:SetOptions(newOptions, keepSelected)
  Dynamically rebuilds the option list inside any existing dropdown.
  Used internally by the config manager to refresh the slot list.
  Also available on any dropdown you create yourself.

  Example:
    local dd = section:AddDropdown("Team", {"Red","Blue"}, nil, cb)
    -- later:
    dd.SetOptions({"Red","Blue","Green"}, "Blue")

UNCHANGED from v2.1:
  - Slider float / decimals param
  - Dropdown scroll-safe, no auto-select, correct screen-space position
  - Save/Load config with writefile / readfile / JSON
  - All element configKey params
  - Notifications (icons removed per no-emoji rule)
]]
