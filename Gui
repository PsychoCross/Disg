                AddCorner(Track,999); AddStroke(Track,Theme.Border,1)
                local Knob=Create("Frame",{Parent=Track,Size=UDim2.new(0,16,0,16),Position=state and UDim2.new(0,27,0.5,-8) or UDim2.new(0,3,0.5,-8),BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=5})
                AddCorner(Knob,999)
                local Ind=Create("Frame",{Parent=row,Size=UDim2.new(0,4,0,20),Position=UDim2.new(0,-6,0.5,-10),BackgroundColor3=state and Theme.Accent or Theme.TextDim,ZIndex=4})
                AddCorner(Ind,4)
                Create("TextButton",{Parent=row,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=6}).MouseButton1Click:Connect(function()
                    state=not state
                    Tween(Track,{BackgroundColor3=state and Theme.ToggleOn or Theme.ToggleOff},0.2)
                    Tween(Knob,{Position=state and UDim2.new(0,27,0.5,-8) or UDim2.new(0,3,0.5,-8)},0.2,Enum.EasingStyle.Back)
                    Tween(Ind,{BackgroundColor3=state and Theme.Accent or Theme.TextDim},0.2)
                    cb(state)
                end)
                local obj={Get=function() return state end,Set=function(v) state=v; Tween(Track,{BackgroundColor3=v and Theme.ToggleOn or Theme.ToggleOff},0.2); Tween(Knob,{Position=v and UDim2.new(0,27,0.5,-8) or UDim2.new(0,3,0.5,-8)},0.2,Enum.EasingStyle.Back); Tween(Ind,{BackgroundColor3=v and Theme.Accent or Theme.TextDim},0.2); cb(v) end}
