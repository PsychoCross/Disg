                })
                AddCorner(HueTrack,999)
                Create("UIGradient",{Parent=HueTrack,
                    Color=ColorSequence.new({
                        ColorSequenceKeypoint.new(0,   Color3.fromHSV(0,1,1)),
                        ColorSequenceKeypoint.new(1/6, Color3.fromHSV(1/6,1,1)),
                        ColorSequenceKeypoint.new(2/6, Color3.fromHSV(2/6,1,1)),
                        ColorSequenceKeypoint.new(3/6, Color3.fromHSV(3/6,1,1)),
                        ColorSequenceKeypoint.new(4/6, Color3.fromHSV(4/6,1,1)),
                        ColorSequenceKeypoint.new(5/6, Color3.fromHSV(5/6,1,1)),
                        ColorSequenceKeypoint.new(1,   Color3.fromHSV(1,1,1)),
                    }),
                })
                local HueThumb=Create("Frame",{
                    Parent=HueTrack,Size=UDim2.new(0,10,0,18),
                    Position=UDim2.new(hue,0-5,0.5,-9),
                    BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=22,
                })
                AddCorner(HueThumb,999)

                -- Brightness slider
                local BrtTrack=Create("Frame",{
                    Parent=CPFrame,Position=UDim2.new(0,8,0,34),
                    Size=UDim2.new(1,-16,0,14),
                    BackgroundColor3=Color3.fromRGB(200,200,200),ZIndex=21,
                })
                AddCorner(BrtTrack,999)

                local function UpdateGradients()
                    local col=Color3.fromHSV(hue,sat,val)
                    Swatch.BackgroundColor3=col
                    HueThumb.Position=UDim2.new(hue,0-5,0.5,-9)
                    callback(col)
                end

                local hSliding,bSliding=false,false
                local HueDrag=Create("TextButton",{Parent=HueTrack,Size=UDim2.new(1,0,0,24),
                    Position=UDim2.new(0,0,0.5,-12),BackgroundTransparency=1,Text="",ZIndex=23})
                HueDrag.MouseButton1Down:Connect(function() hSliding=true end)
                UserInputService.InputChanged:Connect(function(inp)
                    if hSliding and (inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then
                        hue=math.clamp((inp.Position.X-HueTrack.AbsolutePosition.X)/HueTrack.AbsoluteSize.X,0,1)
                        UpdateGradients()
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1 then hSliding=false end
                end)

                local SwatchBtn=Create("TextButton",{Parent=row,Size=UDim2.new(0,34,1,0),Position=UDim2.new(1,-36,0,0),BackgroundTransparency=1,Text="",ZIndex=5})
                SwatchBtn.MouseButton1Click:Connect(function()
                    CPOpen=not CPOpen
                    local absPos=Swatch.AbsolutePosition-ContentHolder.AbsolutePosition
                    CPFrame.Position=UDim2.new(0,absPos.X-120,0,absPos.Y+26)
                    CPFrame.Visible=true
                    Tween(CPFrame,{Size=UDim2.new(0,160,0,CPOpen and 56 or 0)},0.2,Enum.EasingStyle.Back)
                    if not CPOpen then task.delay(0.22,function() CPFrame.Visible=false end) end
                end)

                UpdateGradients()
                return {Get=function() return Color3.fromHSV(hue,sat,val) end}
            end

