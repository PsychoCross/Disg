            end
            local function MakeRow(h)
                return Create("Frame",{Parent=SFrame,Size=UDim2.new(1,0,0,h or 32),BackgroundTransparency=1,ZIndex=3})
            end

            -- BUTTON
            function Section:AddButton(label,cb)
                cb=cb or function()end
                local row=MakeRow(34)
                local Btn=Create("TextButton",{Parent=row,Size=UDim2.new(1,0,1,0),BackgroundColor3=Theme.Surface,Text=label,TextColor3=Theme.TextPrimary,Font=Enum.Font.GothamSemibold,TextSize=13,AutoButtonColor=false,ZIndex=4})
                AddCorner(Btn,8); local bS=AddStroke(Btn,Theme.Border,1.2)
                local function Ripple(x,y)
                    local r=Create("Frame",{Parent=Btn,Size=UDim2.new(0,0,0,0),Position=UDim2.new(0,x-Btn.AbsolutePosition.X,0,y-Btn.AbsolutePosition.Y),BackgroundColor3=Theme.Accent,BackgroundTransparency=0.5,ZIndex=5})
