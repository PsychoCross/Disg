    -- ============================================================
    -- Window object
    -- ============================================================
    local Window = {}
    Window._tabs      = {}
    Window._activeTab = nil
    Window._elements  = {}

    local function SerializeConfig()
        local data = {}
        for _, el in ipairs(Window._elements) do
            data[el.key] = el.get()
        end
        local ok, json = pcall(function()
            return game:GetService("HttpService"):JSONEncode(data)
        end)
        if ok then return json end
        return nil
    end

    local function ApplyConfig(json)
        local ok, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(json)
        end)
        if not ok or type(data) ~= "table" then return false end
        for _, el in ipairs(Window._elements) do
            if data[el.key] ~= nil then
                pcall(function() el.set(data[el.key]) end)
            end
        end
        return true
    end

    function Window:SaveConfig(settingName)
        EnsureFolders()
        settingName = settingName or "default"
        local json = SerializeConfig()
        if not json then
            Window:Notify("Config", "Serialization failed.", "error", 3)
            return
        end
        local saved = false
        pcall(function()
            writefile(SettingFileName(settingName), json)
            AddSettingToList(settingName)
            saved = true
        end)
        if saved then
            Window:Notify("Config", "Saved setting: " .. settingName .. ".cfg", "success", 3)
        else
            print("[ACTED Config Save] " .. settingName .. ":\n" .. json)
            Window:Notify("Config", "Saved to console (no writefile).", "warning", 3)
        end
        return json
    end

    function Window:LoadConfig(settingName, jsonString)
        EnsureFolders()
        settingName = settingName or "default"
        local json = jsonString
        if not json then
            local ok, content = pcall(readfile, SettingFileName(settingName))
            if ok and content then
                json = content
            else
                Window:Notify("Config", "File not found: " .. settingName .. ".cfg", "error", 3)
                return
            end
        end
        if ApplyConfig(json) then
            Window:Notify("Config", "Loaded setting: " .. settingName .. ".cfg", "success", 3)
        else
            Window:Notify("Config", "Load failed: invalid data.", "error", 3)
        end
    end

    function Window:DeleteConfig(settingName)
        EnsureFolders()
        settingName = settingName or "default"
        pcall(function() delfile(SettingFileName(settingName)) end)
        RemoveSettingFromList(settingName)
        Window:Notify("Config", "Deleted setting: " .. settingName .. ".cfg", "info", 3)
    end

    function Window:AddConfigManager(section)
        section:AddLabel("SETTINGS MANAGER", Theme.Accent)
        section:AddDivider()

        local nameBox = section:AddTextbox("Setting name", "Enter setting name...", "", function() end)
        local settingList = ReadSettingList()
        local selectedSetting = nil
        local settingDropdown = nil
        local autoLoadToggle = nil
        local autoLoadData = ReadAutoLoad()

        if autoLoadData.enabled and autoLoadData.setting then
            for _, v in ipairs(settingList) do
                if v == autoLoadData.setting then selectedSetting = v; break end
            end
        end

        local function RefreshDropdown()
            settingList = ReadSettingList()
            if settingDropdown then
                local found = false
                for _, v in ipairs(settingList) do
                    if v == selectedSetting then found = true; break end
                end
                if not found then selectedSetting = nil end
                settingDropdown.SetOptions(settingList, selectedSetting)
            end
        end

        settingDropdown = section:AddDropdown("Select setting", settingList, selectedSetting, function(v)
            selectedSetting = v
            if autoLoadToggle and autoLoadToggle.Get() then
                WriteAutoLoad(true, selectedSetting)
                Window:Notify("Auto Load", "Now auto-loading: " .. tostring(selectedSetting) .. ".cfg", "info", 3)
            end
        end)

        autoLoadToggle = section:AddToggle("Auto Load Setting", autoLoadData.enabled, function(state)
            if state then
                if not selectedSetting or selectedSetting == "" then
                    Window:Notify("Auto Load", "Select a setting first.", "warning", 3)
                    autoLoadToggle.Set(false)
                    WriteAutoLoad(false, nil)
                    return
                end
                WriteAutoLoad(true, selectedSetting)
                Window:Notify("Auto Load", "Enabled for: " .. tostring(selectedSetting) .. ".cfg", "success", 3)
            else
                WriteAutoLoad(false, nil)
                Window:Notify("Auto Load", "Auto load disabled.", "info", 3)
            end
        end)

        section:AddButton("Save setting", function()
            local name = nameBox.Get()
            if not name or name == "" then name = selectedSetting end
            if not name or name == "" then
                Window:Notify("Config", "Type a setting name first.", "warning", 3)
                return
            end
            Window:SaveConfig(name)
            RefreshDropdown()
        end)

        section:AddButton("Load selected setting", function()
            local name = selectedSetting
            if not name or name == "" then
                Window:Notify("Config", "Select a setting from the dropdown.", "warning", 3)
                return
            end
            Window:LoadConfig(name)
        end)

        section:AddButton("Delete selected setting", function()
            local name = selectedSetting
            if not name or name == "" then
                Window:Notify("Config", "Select a setting to delete.", "warning", 3)
                return
            end
            Window:DeleteConfig(name)
            local al = ReadAutoLoad()
            if al.enabled and al.setting == name then
                WriteAutoLoad(false, nil)
                if autoLoadToggle then autoLoadToggle.Set(false) end
            end
            selectedSetting = nil
            RefreshDropdown()
        end)

        section:AddButton("Refresh settings list", function()
            RefreshDropdown()
            Window:Notify("Config", "Settings list refreshed.", "info", 2)
        end)

        section:AddDivider()

        if autoLoadData.enabled and autoLoadData.setting then
            local targetSetting = autoLoadData.setting
            local exists = false
            for _, v in ipairs(ReadSettingList()) do
                if v == targetSetting then exists = true; break end
            end
            if exists then
                task.delay(0.8, function()
                    Window:LoadConfig(targetSetting)
                    selectedSetting = targetSetting
                    settingDropdown.SetOptions(ReadSettingList(), targetSetting)
                end)
            else
                WriteAutoLoad(false, nil)
                if autoLoadToggle then autoLoadToggle.Set(false) end
            end
        end
    end

