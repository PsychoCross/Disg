                Create("TextLabel",{Parent=row,Size=UDim2.new(0.6,0,1,0),BackgroundTransparency=1,Text=label,TextColor3=Theme.TextPrimary,Font=Enum.Font.Gotham,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4})
                local KB=Create("TextButton",{Parent=row,Position=UDim2.new(0.62,0,0.1,0),Size=UDim2.new(0.38,0,0.8,0),BackgroundColor3=Theme.Surface,Text="["..tostring(key.Name).."]",TextColor3=Theme.Accent,Font=Enum.Font.GothamSemibold,TextSize=11,AutoButtonColor=false,ZIndex=4})
