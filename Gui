    -- ScreenGui: mereu in CoreGui, protejat sa nu fie distrus
    local GUI_NAME = "ACTED_"..HubName
    -- Distruge instanta veche daca exista (re-run script)
    local old = CoreGui:FindFirstChild(GUI_NAME)
    if old then old:Destroy() end

    local ScreenGui = Create("ScreenGui",{
        Name=GUI_NAME,
        ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling,
        DisplayOrder=999,
    })
    -- Incearca CoreGui intai (executor), fallback PlayerGui
    local ok = pcall(function() ScreenGui.Parent=CoreGui end)
    if not ok or not ScreenGui.Parent then
        ScreenGui.Parent=LocalPlayer:WaitForChild("PlayerGui")
    end

    -- Protejeaza GUI la respawn: daca iese din parinte, il re-parenta
    local guiConn
    guiConn = ScreenGui.AncestryChanged:Connect(function()
        if not ScreenGui.Parent then
            task.wait()
            pcall(function() ScreenGui.Parent=CoreGui end)
            if not ScreenGui.Parent then
                pcall(function() ScreenGui.Parent=LocalPlayer.PlayerGui end)
            end
        end
    end)

    local blur
    pcall(function()
        blur=Create("BlurEffect",{Parent=Lighting,Size=0})
        Tween(blur,{Size=4},0.5)
    end)

    -- Main frame
    local Main=Create("Frame",{
        Name="Main",Parent=ScreenGui,
        BackgroundColor3=Theme.Background,
        Position=UDim2.new(0.5,-280,0.5,-210),
        Size=UDim2.new(0,0,0,0),
        BackgroundTransparency=1,
        ClipsDescendants=true,
    })
    AddCorner(Main,14)
    local mainStroke=AddStroke(Main,Theme.Border,1.5)
    PulseGlow(mainStroke,Theme.Border,Theme.BorderGlow,1.2)
    Tween(Main,{Size=Size,BackgroundTransparency=0},0.45,Enum.EasingStyle.Back,Enum.EasingDirection.Out)

    -- Ambient gradient
