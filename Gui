            -- ==========================
            -- SLIDER (float support)
            -- ==========================
            function Section:AddSlider(label, min, max, default, callback, decimals, configKey)
                min      = min      or 0
                max      = max      or 100
                decimals = decimals or 0
                default  = RoundTo(math.clamp(default or min, min, max), decimals)
                callback = callback or function() end
                local value = default

                local row = MakeRow(52)

                local LabelRow = Create("Frame", {Parent = row, Size = UDim2.new(1, 0, 0, 20), BackgroundTransparency = 1, ZIndex = 4})
                Create("TextLabel", {
                    Parent = LabelRow, Size = UDim2.new(0.7, 0, 1, 0),
                    BackgroundTransparency = 1, Text = label,
                    TextColor3 = Theme.TextPrimary, Font = Enum.Font.Gotham, TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
                })
                local ValLabel = Create("TextLabel", {
                    Parent = LabelRow, Position = UDim2.new(0.7, 0, 0, 0),
                    Size = UDim2.new(0.3, 0, 1, 0), BackgroundTransparency = 1,
                    Text = tostring(default),
                    TextColor3 = Theme.Accent, Font = Enum.Font.GothamBold, TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 4,
                })

                local Track = Create("Frame", {
                    Parent = row, Position = UDim2.new(0, 0, 0, 28),
                    Size = UDim2.new(1, 0, 0, 8),
                    BackgroundColor3 = Theme.ToggleOff, ZIndex = 4,
                })
                AddCorner(Track, 999)
                AddStroke(Track, Theme.Border, 1)

                local Fill = Create("Frame", {
                    Parent = Track,
                    Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
                    BackgroundColor3 = Theme.SliderFill, ZIndex = 5,
                })
                AddCorner(Fill, 999)
                Create("UIGradient", {Parent = Fill,
                    Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Theme.Accent),
                        ColorSequenceKeypoint.new(1, Theme.AccentGlow),
                    }),
                })

                local Thumb = Create("Frame", {
                    Parent = Track, Size = UDim2.new(0, 14, 0, 14),
                    Position = UDim2.new((default - min) / (max - min), 0 - 7, 0.5, -7),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255), ZIndex = 6,
                })
                AddCorner(Thumb, 999)
                AddStroke(Thumb, Theme.Accent, 1.5)

                local SliderBtn = Create("TextButton", {
                    Parent = Track, Size = UDim2.new(1, 0, 0, 24),
                    Position = UDim2.new(0, 0, 0.5, -12),
                    BackgroundTransparency = 1, Text = "", ZIndex = 7,
                })

                local sliding = false

                local function UpdateSlider(inputX)
                    local rel = math.clamp((inputX - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    value = RoundTo(min + rel * (max - min), decimals)
                    if decimals > 0 then
                        ValLabel.Text = string.format("%." .. decimals .. "f", value)
                    else
                        ValLabel.Text = tostring(value)
                    end
                    local fillRel = (value - min) / (max - min)
                    Tween(Fill, {Size = UDim2.new(fillRel, 0, 1, 0)}, 0.05)
                    Tween(Thumb, {Position = UDim2.new(fillRel, 0 - 7, 0.5, -7)}, 0.05)
                    callback(value)
                end

                SliderBtn.MouseButton1Down:Connect(function()
                    sliding = true
                    local mp = UserInputService:GetMouseLocation()
                    UpdateSlider(mp.X)
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if not sliding then return end
                    if input.UserInputType == Enum.UserInputType.MouseMovement
                    or input.UserInputType == Enum.UserInputType.Touch then
                        UpdateSlider(input.Position.X)
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = false
                    end
                end)

                local function SetSlider(v)
                    v = RoundTo(math.clamp(v, min, max), decimals)
                    local rel = (v - min) / (max - min)
                    local px  = Track.AbsolutePosition.X + rel * Track.AbsoluteSize.X
                    UpdateSlider(px)
                end

                local obj = {
                    Value = value,
                    Set   = SetSlider,
                    Get   = function() return value end
                }
                if configKey then
                    table.insert(Window._elements, {key = configKey, get = function() return value end, set = SetSlider})
                end
                return obj
            end

