                    callback(col)
                end

                local hSliding = false
                local HueDrag = Create("TextButton", {
                    Parent = HueTrack, Size = UDim2.new(1, 0, 0, 24),
                    Position = UDim2.new(0, 0, 0.5, -12), BackgroundTransparency = 1, Text = "", ZIndex = 53,
                })
                HueDrag.MouseButton1Down:Connect(function() hSliding = true end)
                UserInputService.InputChanged:Connect(function(inp)
                    if hSliding and (inp.UserInputType == Enum.UserInputType.MouseMovement
                                  or inp.UserInputType == Enum.UserInputType.Touch) then
                        hue = math.clamp((inp.Position.X - HueTrack.AbsolutePosition.X) / HueTrack.AbsoluteSize.X, 0, 1)
                        UpdateColor()
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then hSliding = false end
                end)

                local SwatchBtn = Create("TextButton", {
                    Parent = row, Size = UDim2.new(0, 34, 1, 0),
                    Position = UDim2.new(1, -36, 0, 0),
                    BackgroundTransparency = 1, Text = "", ZIndex = 5,
                })
                SwatchBtn.MouseButton1Click:Connect(function()
                    CPOpen = not CPOpen
                    local absPos = Swatch.AbsolutePosition
                    CPFrame.Position = UDim2.new(0, absPos.X - 120, 0, absPos.Y + 26)
                    CPFrame.Visible = true
                    Tween(CPFrame, {Size = UDim2.new(0, 160, 0, CPOpen and 56 or 0)}, 0.2, Enum.EasingStyle.Back)
                    if not CPOpen then task.delay(0.22, function() CPFrame.Visible = false end) end
                end)

                UpdateColor()

                local function GetColor() return Color3.fromHSV(hue, sat, val_cp) end
                local obj = {Get = GetColor}
                if configKey then
                    table.insert(Window._elements, {key = configKey,
                        get = function()
                            local c = GetColor()
                            return {r = c.R, g = c.G, b = c.B}
                        end,
                        set = function(v)
                            if type(v) == "table" then
                                local col = Color3.new(v.r, v.g, v.b)
                                hue, sat, val_cp = Color3.toHSV(col)
                                UpdateColor()
                            end
                        end})
                end
                return obj
            end

            -- ==========================
            -- LABEL
            -- ==========================
            function Section:AddLabel(text, color)
                local row = MakeRow(22)
                Create("TextLabel", {
                    Parent = row, Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1, Text = text,
                    TextColor3 = color or Theme.TextSecondary,
                    Font = Enum.Font.Gotham, TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 4, TextWrapped = true,
                })
            end

            -- ==========================
            -- KEYBIND
            -- ==========================
            function Section:AddKeybind(label, default, callback, configKey)
                callback = callback or function() end
                default  = default  or Enum.KeyCode.RightShift
                local key = default
                local listening = false
                local row = MakeRow(34)
                Create("TextLabel", {
                    Parent = row, Size = UDim2.new(0.6, 0, 1, 0),
                    BackgroundTransparency = 1, Text = label,
                    TextColor3 = Theme.TextPrimary, Font = Enum.Font.Gotham, TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
                })
                local KBtn = Create("TextButton", {
                    Parent = row, Position = UDim2.new(0.62, 0, 0.1, 0),
                    Size = UDim2.new(0.38, 0, 0.8, 0),
                    BackgroundColor3 = Theme.Surface,
                    Text = "[" .. tostring(key.Name) .. "]",
                    TextColor3 = Theme.Accent, Font = Enum.Font.GothamSemibold, TextSize = 11,
                    AutoButtonColor = false, ZIndex = 4,
                })
                AddCorner(KBtn, 7)
                AddStroke(KBtn, Theme.Border, 1)
                KBtn.MouseButton1Click:Connect(function()
                    listening = true
                    KBtn.Text = "[...]"
                    KBtn.TextColor3 = Theme.Warning
                end)
                UserInputService.InputBegan:Connect(function(inp)
                    if listening and inp.UserInputType == Enum.UserInputType.Keyboard then
                        key = inp.KeyCode
                        KBtn.Text = "[" .. tostring(key.Name) .. "]"
                        KBtn.TextColor3 = Theme.Accent
                        listening = false
                    end
                    if not listening and inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == key then
                        callback(key)
                    end
                end)
                local obj = {Get = function() return key end}
                if configKey then
                    table.insert(Window._elements, {key = configKey,
                        get = function() return key.Name end,
                        set = function(v)
                            local ok, kc = pcall(function() return Enum.KeyCode[v] end)
                            if ok and kc then key = kc; KBtn.Text = "[" .. v .. "]" end
                        end})
                end
                return obj
            end

            -- ==========================
            -- DIVIDER
            -- ==========================
            function Section:AddDivider()
                local row = MakeRow(10)
                Create("Frame", {
                    Parent = row, Size = UDim2.new(1, 0, 0, 1),
                    Position = UDim2.new(0, 0, 0.5, 0),
                    BackgroundColor3 = Theme.Border, BorderSizePixel = 0, ZIndex = 4,
                })
            end

            table.insert(tabData._sections, Section)
            return Section
        end

        return tabData
    end

    -- ============================================================
    -- Beautiful Animated Notifications (RefńÉcut complet)
    -- ============================================================
    function Window:Notify(title, message, ntype, duration)
        ntype    = ntype    or "info"
        duration = duration or 3
        
        local colors = {info = Theme.Accent, success = Theme.Success, warning = Theme.Warning, error = Theme.Danger}
        local icons  = {info = "i", success = "‚úď", warning = "!", error = "‚úē"}
        local col  = colors[ntype] or Theme.Accent
        local icon = icons[ntype]  or "i"

        -- Container Holder (Partea de jos-dreapta, cu padding)
        local NHolder = ScreenGui:FindFirstChild("ACTED_NotifHolder")
        if not NHolder then
            NHolder = Create("Frame", {
                Name = "ACTED_NotifHolder", Parent = ScreenGui,
                Position = UDim2.new(1, -340, 1, -40),
                Size = UDim2.new(0, 320, 0, 0),
                BackgroundTransparency = 1, ZIndex = 200,
            })
            Create("UIListLayout", {
                Parent = NHolder, VerticalAlignment = Enum.VerticalAlignment.Bottom,
                HorizontalAlignment = Enum.HorizontalAlignment.Right,
                SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 12),
            })
        end

        -- Wrapper invizibil cu maska - aici se va face animatia de height
        -- ClipsDescendants blocheaza glisarea sa nu iasa afara din perimetrul alocat
        local NWrap = Create("Frame", {
            Parent = NHolder, Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1, ClipsDescendants = true, ZIndex = 200,
        })

        -- Box-ul principal de notificare
        local NFrame = Create("Frame", {
            Parent = NWrap, Size = UDim2.new(1, 0, 0, 85),
            Position = UDim2.new(0, 350, 0, 0), -- PleacńÉ de pe dreapta, ascuns de wrapper
            BackgroundColor3 = Theme.Surface,
            BackgroundTransparency = 0.05,
            ZIndex = 200,
        })
        AddCorner(NFrame, 12)
        local nStroke = AddStroke(NFrame, col, 1.5, 0.2)
        
        -- Gradient modern peste background
        Create("UIGradient", {
            Parent = NFrame, Rotation = 45,
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
                ColorSequenceKeypoint.new(1, Color3.new(0.8,0.8,0.8))
            })
        })

        -- Iconi»õńÉ stilizatńÉ
        local iconRing = Create("Frame", {
            Parent = NFrame, Position = UDim2.new(0, 15, 0.5, -20),
            Size = UDim2.new(0, 40, 0, 40),
            BackgroundColor3 = Theme.SurfaceAlt, ZIndex = 201,
        })
        AddCorner(iconRing, 20)
        AddStroke(iconRing, col, 1.5, 0)
        
        local iconGlow = Create("Frame", {
            Parent = iconRing, Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = col, BackgroundTransparency = 0.85, ZIndex = 200
        })
        AddCorner(iconGlow, 20)

        Create("TextLabel", {
            Parent = iconRing, Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1, Text = icon,
            TextColor3 = col, Font = Enum.Font.GothamBlack, TextSize = 16, ZIndex = 202,
        })

        -- Structura textului
        local TextHolder = Create("Frame", {
            Parent = NFrame, Position = UDim2.new(0, 70, 0, 0),
            Size = UDim2.new(1, -85, 1, -12), BackgroundTransparency = 1, ZIndex = 201
        })
        Create("UIListLayout", {
            Parent = TextHolder, SortOrder = Enum.SortOrder.LayoutOrder,
            VerticalAlignment = Enum.VerticalAlignment.Center, Padding = UDim.new(0, 4)
        })

        Create("TextLabel", {
            Parent = TextHolder, Size = UDim2.new(1, 0, 0, 18),
            BackgroundTransparency = 1, Text = title,
            TextColor3 = Theme.TextPrimary, Font = Enum.Font.GothamBold, TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 201,
        })
        Create("TextLabel", {
            Parent = TextHolder, Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1, Text = message,
            TextColor3 = Theme.TextSecondary, Font = Enum.Font.GothamMedium, TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top,
            TextWrapped = true, AutomaticSize = Enum.AutomaticSize.Y, ZIndex = 201,
        })

        -- Bara de progres (timer)
        local ProgBG = Create("Frame", {
            Parent = NFrame, Size = UDim2.new(1, -30, 0, 3),
            Position = UDim2.new(0, 15, 1, -8),
            BackgroundColor3 = Theme.SurfaceAlt, BackgroundTransparency = 0.5,
            BorderSizePixel = 0, ZIndex = 201,
        })
        AddCorner(ProgBG, 2)
        local ProgFill = Create("Frame", {
            Parent = ProgBG, Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = col, BorderSizePixel = 0, ZIndex = 202,
        })
        AddCorner(ProgFill, 2)

        -- Anima»õia de intrare (super fluidńÉ, ExponentialńÉ)
        Tween(NWrap, {Size = UDim2.new(1, 0, 0, 85)}, 0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
        task.delay(0.1, function()
            Tween(NFrame, {Position = UDim2.new(0, 0, 0, 0)}, 0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
        end)

        -- Anima»õia timer-ului (scade progresiv p√ĘnńÉ la ie»ôire)
        Tween(ProgFill, {Size = UDim2.new(0, 0, 1, 0)}, duration, Enum.EasingStyle.Linear)

        -- Anima»õia de ie»ôire
        task.delay(duration, function()
            -- Dispare spre dreapta (acoperit de mask)
            Tween(NFrame, {Position = UDim2.new(0, 350, 0, 0), BackgroundTransparency = 1}, 0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.In)
            task.delay(0.4, function()
                -- Str√Ęnge √ģnńÉl»õimea pentru a lńÉsa celelalte notificńÉri sńÉ urce lin
                Tween(NWrap, {Size = UDim2.new(1, 0, 0, 0)}, 0.3, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
                task.delay(0.3, function() NWrap:Destroy() end)
            end)
        end)
    end

    task.delay(0.6, function()
        Window:Notify("ACTED", "Loaded core modules.", "success", 3)
    end)

    return Window
end

return ACTED
