            function Section:AddToggle(label,default,cb,key)
                cb=cb or function()end; local state=default or false
                local row=MakeRow(34)
                Create("TextLabel",{Parent=row,Size=UDim2.new(1,-58,1,0),BackgroundTransparency=1,Text=label,TextColor3=Theme.TextPrimary,Font=Enum.Font.Gotham,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4})
