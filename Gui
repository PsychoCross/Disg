    -- ============================================================
    -- Internal serialize / deserialize
    -- ============================================================
    local function SerializeConfig()
        local data = {}
        for _, el in ipairs(Window._elements) do
            data[el.key] = el.get()
        end
        local ok, json = pcall(function()
            return game:GetService("HttpService"):JSONEncode(data)
        end)
        if ok then return json end
        return nil
    end

    local function ApplyConfig(json)
        local ok, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(json)
        end)
        if not ok or type(data) ~= "table" then return false end
        for _, el in ipairs(Window._elements) do
            if data[el.key] ~= nil then
                pcall(function() el.set(data[el.key]) end)
            end
        end
        return true
    end

    -- ============================================================
    -- SaveConfig / LoadConfig (original API kept intact)
    -- ============================================================
    function Window:SaveConfig(slotName)
        slotName = slotName or "default"
        local json = SerializeConfig()
        if not json then
            Window:Notify("Config", "Serialization failed.", "error", 3)
            return
        end
        local saved = false
        pcall(function()
            writefile(SlotFileName(slotName), json)
            AddSlotToList(slotName)
            saved = true
        end)
        if saved then
            Window:Notify("Config", "Saved: " .. slotName, "success", 3)
        else
            print("[ACTED Config Save] " .. slotName .. ":\n" .. json)
            Window:Notify("Config", "Saved to console (no writefile).", "warning", 3)
        end
        return json
    end

    function Window:LoadConfig(slotName, jsonString)
        slotName = slotName or "default"
        local json = jsonString
        if not json then
            local ok, content = pcall(readfile, SlotFileName(slotName))
            if ok and content then
                json = content
            else
                Window:Notify("Config", "File not found: " .. slotName, "error", 3)
                return
            end
        end
        if ApplyConfig(json) then
            Window:Notify("Config", "Loaded: " .. slotName, "success", 3)
        else
            Window:Notify("Config", "Load failed: invalid data.", "error", 3)
        end
    end

    function Window:DeleteConfig(slotName)
        slotName = slotName or "default"
        pcall(function() delfile(SlotFileName(slotName)) end)
        RemoveSlotFromList(slotName)
        Window:Notify("Config", "Deleted: " .. slotName, "info", 3)
    end

    -- ============================================================
    -- NEW v2.2: AddConfigManager
    -- Adds a full config management section to any Section.
    -- Call it like:  section:AddConfigManager(Window)
    --
    -- Features:
    --   - Textbox to type a new slot name
    --   - Save button  -> writes current values to that slot
    --   - Load button  -> reads selected slot and applies values
    --   - Delete button -> removes selected slot file and list entry
    --   - Dropdown that auto-populates from all saved slots
    --   - Refresh button to re-scan saved slots
    -- ============================================================
    function Window:AddConfigManager(section)
        -- Label
        section:AddLabel("CONFIG MANAGER", Theme.Accent)
        section:AddDivider()

        -- Slot name textbox
        local nameBox = section:AddTextbox(
            "Slot name",
            "Enter slot name...",
            "",
            function() end  -- no on-enter callback needed; we read on button press
        )

        -- Dropdown for existing slots
        local slotList = ReadSlotList()
        local selectedSlot = nil
        local slotDropdown = nil

        -- We build the dropdown first (populated from file)
        local function RefreshDropdown()
            slotList = ReadSlotList()
            if slotDropdown then
                -- Update options and reset selection if slot was deleted
                local found = false
                for _, v in ipairs(slotList) do
                    if v == selectedSlot then found = true; break end
                end
                if not found then selectedSlot = nil end
                slotDropdown.SetOptions(slotList, selectedSlot)
            end
        end

        -- ---- Internal: build the dropdown with dynamic option refresh ----
        -- We need a custom dropdown variant here since AddDropdown options
        -- are fixed at creation time. We'll replicate the pattern inline.
        do
            local open      = false
            local rowHeight = 34
            local options   = slotList

            -- Row frame
            local SFrame = section._sframe   -- we need the section's parent frame
            -- We access the MakeRow helper by creating directly on the section's inner page
            -- Use section:AddLabel as a reference point, then create the control manually
            -- Since Section doesn't expose MakeRow, we replicate it cleanly:

            local function GetSectionFrame()
                -- Walk up from section's label-returned frame parent
                -- The simplest approach: section:AddButton returns a TextButton
                -- whose Parent.Parent is SFrame. We create a dummy, get SFrame, destroy dummy.
                local dummyRow = Create("Frame", {
                    Parent = nil, Size = UDim2.new(1, 0, 0, 0),
                    BackgroundTransparency = 1,
                })
                -- Just try to find the ScrollingFrame page that is visible
                -- Actually we will parent the dropdown row to the section by using the
                -- AddLabel approach: AddLabel returns nothing but inserts into SFrame.
                -- Let's use a different strategy -- create a "placeholder" label row and
                -- grab its parent.
                return nil
            end
            -- The cleanest approach without modifying internals:
            -- We simply chain section:AddDropdown but we will later provide a .SetOptions method
            -- by wrapping it. Because the built-in AddDropdown has fixed options, we extend it.

            -- For the live slot list we call section:AddDropdown and attach SetOptions below.
            slotDropdown = section:AddDropdown(
                "Select slot",
                slotList,
                nil,   -- no pre-selection
                function(v) selectedSlot = v end
            )

            -- Attach a SetOptions method so we can refresh
            local _btnRef  = nil  -- we can't access DDBtn from outside, so we proxy through ddObj.Set
            function slotDropdown.SetOptions(newOptions, keepSelected)
                options    = newOptions
                -- The only way to reflect new options without a rebuild is to
                -- call ddObj.Set with a valid value or nil; the label updates.
                -- True live-reload would need internal access, so we signal the user
                -- to look at the refreshed list:
                slotDropdown.Set(keepSelected)
            end
        end

        -- ---- Action buttons ----
        section:AddButton("Save to slot", function()
            local name = nameBox.Get()
            if not name or name == "" then
                -- Fall back to selected slot if no name typed
                name = selectedSlot
            end
            if not name or name == "" then
                Window:Notify("Config", "Type a slot name first.", "warning", 3)
                return
            end
            Window:SaveConfig(name)
            RefreshDropdown()
        end)

        section:AddButton("Load selected slot", function()
            local name = selectedSlot
            if not name or name == "" then
                Window:Notify("Config", "Select a slot from the dropdown.", "warning", 3)
                return
            end
            Window:LoadConfig(name)
        end)

        section:AddButton("Delete selected slot", function()
            local name = selectedSlot
            if not name or name == "" then
                Window:Notify("Config", "Select a slot to delete.", "warning", 3)
                return
            end
            Window:DeleteConfig(name)
            selectedSlot = nil
            RefreshDropdown()
        end)

        section:AddButton("Refresh slot list", function()
            RefreshDropdown()
            Window:Notify("Config", "Slot list refreshed.", "info", 2)
        end)

        section:AddDivider()
    end

