-- ============================================================
-- Config / Folder System
-- ============================================================
local HUB_FOLDER      = "ACTED"
local CONFIG_FOLDER   = HUB_FOLDER .. "/configs"
local SETTINGS_FOLDER = HUB_FOLDER .. "/settings"
local SETTINGS_FILE   = SETTINGS_FOLDER .. "/ACTED_settings.json"
local AUTOLOAD_FILE   = SETTINGS_FOLDER .. "/ACTED_autoload.json"

local function EnsureFolders()
    pcall(function()
        if not isfolder(HUB_FOLDER)      then makefolder(HUB_FOLDER)      end
        if not isfolder(CONFIG_FOLDER)   then makefolder(CONFIG_FOLDER)   end
        if not isfolder(SETTINGS_FOLDER) then makefolder(SETTINGS_FOLDER) end
    end)
end

local function SettingFileName(name) return CONFIG_FOLDER .. "/" .. name .. ".cfg" end

local function ReadSettingList()
    EnsureFolders()
    local ok, raw = pcall(readfile, SETTINGS_FILE)
    if not ok or not raw then return {} end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if ok2 and type(data) == "table" then return data end
    return {}
end

local function WriteSettingList(list)
    EnsureFolders()
    local ok, json = pcall(function() return HttpService:JSONEncode(list) end)
    if ok then pcall(writefile, SETTINGS_FILE, json) end
end

local function AddSettingToList(name)
    local list = ReadSettingList()
    for _, v in ipairs(list) do if v == name then return end end
    table.insert(list, name); WriteSettingList(list)
end

local function RemoveSettingFromList(name)
    local list = ReadSettingList()
    local new = {}
    for _, v in ipairs(list) do if v ~= name then table.insert(new, v) end end
    WriteSettingList(new)
end

local function ReadAutoLoad()
    EnsureFolders()
    local ok, raw = pcall(readfile, AUTOLOAD_FILE)
    if not ok or not raw then return {enabled = false, setting = nil} end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if ok2 and type(data) == "table" then return {enabled = data.enabled == true, setting = data.setting} end
    return {enabled = false, setting = nil}
end

local function WriteAutoLoad(enabled, setting)
    EnsureFolders()
    local ok, json = pcall(function() return HttpService:JSONEncode({enabled = enabled, setting = setting}) end)
    if ok then pcall(writefile, AUTOLOAD_FILE, json) end
end

