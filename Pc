            -- ==========================
            -- DROPDOWN
            -- ==========================
            function Section:AddDropdown(label, options, default, cb, cfgKey)
                cb = cb or function() end; options = options or {}
                local selected = default; local open = false; local renderConn = nil
                local row = Row(30)

                Create("TextLabel", {
                    Parent=row, Size=UDim2.new(0.42,0,1,0),
                    BackgroundTransparency=1, Text=label,
                    TextColor3=Theme.TextPri, Font=Enum.Font.Gotham, TextSize=12,
                    TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5,
                })

                local function BtnLbl() return (selected or "Select...") .. "  ‚Ėĺ" end

                local DDBtn = Create("TextButton", {
                    Parent=row, Position=UDim2.new(0.44,0,0.1,0),
                    Size=UDim2.new(0.56,0,0.8,0),
                    BackgroundColor3=Theme.Panel,
                    Text=BtnLbl(),
                    TextColor3=selected and Theme.TextPri or Theme.TextDim,
                    Font=Enum.Font.Gotham, TextSize=11,
                    AutoButtonColor=false, ZIndex=5,
                })
                Corner(DDBtn, 7)
                local dds = Stroke(DDBtn, Theme.Border, 1)

                local Overlay = Create("TextButton", {
                    Parent=ScreenGui, Size=UDim2.new(1,0,1,0),
                    BackgroundTransparency=1, Text="", ZIndex=49, Visible=false, AutoButtonColor=false,
                })
                local DDList = Create("ScrollingFrame", {
                    Parent=ScreenGui, Size=UDim2.new(0,0,0,0),
                    BackgroundColor3=Theme.Card,
                    Visible=false, ZIndex=50, ClipsDescendants=true,
                    ScrollBarThickness=2, ScrollBarImageColor3=Theme.Accent,
                    CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
                    BorderSizePixel=0,
                })
                Corner(DDList, 8)
                Stroke(DDList, Theme.Accent, 1.2)
                Create("UIListLayout", {Parent=DDList, SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0,2)})
                Pad(DDList, 4,4,4,4)

                local function CloseDD()
                    if not open then return end
                    open = false
                    if renderConn then renderConn:Disconnect(); renderConn=nil end
                    if _openDropdown and _openDropdown.list==DDList then _openDropdown=nil end
                    Overlay.Visible=false; DDList.Visible=false
                    DDList.Size=UDim2.new(0,DDList.Size.X.Offset,0,0)
                    DDBtn.Text=BtnLbl()
                end
                Overlay.MouseButton1Click:Connect(CloseDD)

                local function Build(opts)
                    for _, c in ipairs(DDList:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                    for _, opt in ipairs(opts) do
                        local OB = Create("TextButton", {
                            Parent=DDList, Size=UDim2.new(1,0,0,24),
                            BackgroundColor3=Theme.Panel,
                            Text=opt, TextColor3=opt==selected and Theme.Accent or Theme.TextPri,
                            Font=Enum.Font.Gotham, TextSize=12, AutoButtonColor=false, ZIndex=51,
                        })
                        Corner(OB, 6)
                        OB.MouseEnter:Connect(function() Tween(OB,{BackgroundColor3=Theme.CardHover},0.1) end)
                        OB.MouseLeave:Connect(function() Tween(OB,{BackgroundColor3=Theme.Panel},0.1) end)
                        OB.MouseButton1Click:Connect(function()
                            selected=opt; DDBtn.Text=BtnLbl(); DDBtn.TextColor3=Theme.TextPri
                            for _,c2 in ipairs(DDList:GetChildren()) do
                                if c2:IsA("TextButton") then c2.TextColor3=c2.Text==selected and Theme.Accent or Theme.TextPri end
                            end
                            CloseDD(); cb(selected)
                        end)
                    end
                end
                Build(options)

                local function OpenDD()
                    if _openDropdown then _openDropdown.close() end
                    open=true; _openDropdown={close=CloseDD,list=DDList}
                    local btnW = DDBtn.AbsoluteSize.X
                    local targetH = math.min(#options*28+10, 160)
                    DDList.Size=UDim2.new(0,btnW,0,0); DDList.Visible=true; Overlay.Visible=true
                    renderConn=RunService.RenderStepped:Connect(function()
                        local ap = DDBtn.AbsolutePosition
                        local bs2 = DDBtn.AbsoluteSize
                        local hub2 = Main.AbsolutePosition.Y + Main.AbsoluteSize.Y
                        local below = hub2 - (ap.Y + bs2.Y)
                        local isUp = below < targetH
                        local curH = DDList.AbsoluteSize.Y
                        DDList.Position = UDim2.new(0, ap.X, 0, isUp and (ap.Y-curH-4) or (ap.Y+bs2.Y+4))
                    end)
                    Tween(DDList, {Size=UDim2.new(0,btnW,0,targetH)}, 0.18, Enum.EasingStyle.Back)
                    DDBtn.Text = (selected or "Select...") .. "  ‚Ėī"
                end

                DDBtn.MouseButton1Click:Connect(function() if open then CloseDD() else OpenDD() end end)
                DDBtn.MouseEnter:Connect(function() Tween(dds,{Color=Theme.Accent},0.12) end)
                DDBtn.MouseLeave:Connect(function() Tween(dds,{Color=Theme.Border},0.12) end)

                local ddObj = {
                    Get=function() return selected end,
                    Set=function(v) selected=v; DDBtn.Text=BtnLbl(); DDBtn.TextColor3=selected and Theme.TextPri or Theme.TextDim; cb(v) end,
                    SetOptions=function(newOpts, keep)
                        options=newOpts or {}
                        local valid=false
                        for _,v in ipairs(options) do if v==keep then valid=true; break end end
                        selected=valid and keep or nil
                        DDBtn.Text=BtnLbl(); DDBtn.TextColor3=selected and Theme.TextPri or Theme.TextDim
                        Build(options)
                    end,
                }
                if cfgKey then table.insert(_elements,{key=cfgKey,get=function() return selected end,set=ddObj.Set}) end
                return ddObj
            end

