    local function ApplyTheme(newThemeName)
        local t = Themes[newThemeName]
        if not t then return end
        Theme = t
        ThemeBtn.Text = "‚óĎ  " .. Theme.Name
        -- Update main surfaces
        Main.BackgroundColor3 = Theme.Background
        BgGrad.BackgroundColor3 = Theme.Background
        bgGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Theme.SurfaceAlt),
            ColorSequenceKeypoint.new(0.5, Theme.Background),
            ColorSequenceKeypoint.new(1, Theme.Background),
        })
        mainStroke.Color = Theme.Border
        TopBar.BackgroundColor3 = Theme.TopBar
        TabBar.BackgroundColor3 = Theme.TopBar
        TabBarBorder.BackgroundColor3 = Theme.Border
        ThemeBtn.TextColor3 = Theme.Accent
        ThemeBtn.BackgroundColor3 = Theme.SurfaceAlt
        -- Tabs will visually update on next activate
        for _, tab in ipairs(Window._tabs) do
            local isActive = (Window._activeTab == tab)
            tab._btn.TextColor3 = isActive and Theme.TextPrimary or Theme.TextSecondary
            tab._btn.BackgroundColor3 = isActive and Theme.SurfaceAlt or Color3.fromRGB(0,0,0)
            tab._btn.BackgroundTransparency = isActive and 0.3 or 1
            tab._indicator.BackgroundColor3 = isActive and Theme.TabLine or Color3.fromRGB(0,0,0)
            tab._indicator.BackgroundTransparency = isActive and 0 or 1
        end
    end

    local _currentThemeIdx = (StartTheme == "Ember") and 2 or 1
    local _themeOrder = {"NeonFrost", "Ember"}
    ThemeBtn.MouseButton1Click:Connect(function()
        _currentThemeIdx = (_currentThemeIdx % #_themeOrder) + 1
