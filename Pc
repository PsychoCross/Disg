                    TextColor3 = Theme.Accent, Font = Enum.Font.GothamBold, TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 4,
                })

                -- Track
                local TrackBG = Create("Frame", {
                    Parent = row, Position = UDim2.new(0, 0, 0, 26),
                    Size = UDim2.new(1, 0, 0, 6),
                    BackgroundColor3 = Theme.ToggleOff, ZIndex = 4,
                })
                AddCorner(TrackBG, 999)

                local Fill = Create("Frame", {
                    Parent = TrackBG,
                    Size = UDim2.new((default - min)/(max - min), 0, 1, 0),
                    BackgroundColor3 = Theme.SliderFill, ZIndex = 5,
                })
                AddCorner(Fill, 999)
                Create("UIGradient", {
                    Parent = Fill,
                    Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Theme.Accent),
                        ColorSequenceKeypoint.new(1, Theme.AccentGlow),
                    }),
                })

                local Thumb = Create("Frame", {
                    Parent = TrackBG, Size = UDim2.new(0, 12, 0, 12),
                    Position = UDim2.new((default-min)/(max-min), 0-6, 0.5, -6),
                    BackgroundColor3 = Color3.fromRGB(255,255,255), ZIndex = 6,
                })
                AddCorner(Thumb, 999)
                AddStroke(Thumb, Theme.Accent, 1.5)

                local SliderBtn = Create("TextButton", {
                    Parent = TrackBG, Size = UDim2.new(1, 0, 0, 22),
                    Position = UDim2.new(0, 0, 0.5, -11),
                    BackgroundTransparency = 1, Text = "", ZIndex = 7,
                })

                local sliding = false
                local function UpdateSlider(inputX)
                    local rel = math.clamp((inputX - TrackBG.AbsolutePosition.X) / TrackBG.AbsoluteSize.X, 0, 1)
                    value = RoundTo(min + rel*(max-min), decimals)
                    if decimals > 0 then ValLabel.Text = string.format("%."..decimals.."f", value)
                    else ValLabel.Text = tostring(value) end
                    local fr = (value - min)/(max - min)
                    Tween(Fill, {Size = UDim2.new(fr, 0, 1, 0)}, 0.04)
                    Tween(Thumb, {Position = UDim2.new(fr, -6, 0.5, -6)}, 0.04)
                    callback(value)
                end

                SliderBtn.MouseButton1Down:Connect(function()
                    sliding = true
                    UpdateSlider(UserInputService:GetMouseLocation().X)
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if not sliding then return end
                    if inp.UserInputType == Enum.UserInputType.MouseMovement
                    or inp.UserInputType == Enum.UserInputType.Touch then UpdateSlider(inp.Position.X) end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1
                    or inp.UserInputType == Enum.UserInputType.Touch then sliding = false end
                end)

                local function SetSlider(v)
                    v = RoundTo(math.clamp(v, min, max), decimals)
                    local rel = (v - min)/(max - min)
                    UpdateSlider(TrackBG.AbsolutePosition.X + rel * TrackBG.AbsoluteSize.X)
                end

                local obj = {Value = value, Set = SetSlider, Get = function() return value end}
                if configKey then
                    table.insert(Window._elements, {key = configKey, get = function() return value end, set = SetSlider})
                end
                return obj
            end

