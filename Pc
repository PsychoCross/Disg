                })
                local function SetState(val)
                    state = val
                    Tween(Track, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.2)
                    Tween(TrackGlow, {BackgroundTransparency = state and 0.7 or 1}, 0.2)
                    Tween(Knob, {Position = state and UDim2.new(0, 28, 0.5, -8) or UDim2.new(0, 4, 0.5, -8)}, 0.22, Enum.EasingStyle.Back)
