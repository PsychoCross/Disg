            -- ===========================
            -- 2-COLUMN ROW (side by side elements)
            -- ===========================
            function Section:AddRow(leftFn, rightFn)
                -- leftFn and rightFn are functions that receive a "mini section"
                -- and call Add* on it. They share the same parent row.
                local row = MakeRow(36)
                local Left = Create("Frame", {
                    Parent = row, Size = UDim2.new(0.5, -4, 1, 0),
                    BackgroundTransparency = 1, ZIndex = 3,
                })
                local Right = Create("Frame", {
                    Parent = row, Position = UDim2.new(0.5, 4, 0, 0),
                    Size = UDim2.new(0.5, -4, 1, 0),
                    BackgroundTransparency = 1, ZIndex = 3,
                })
                -- Wrap them like mini sections
                local function wrapMini(parent)
                    local mini = {}
                    function mini:AddButton(label, cb) cb = cb or function() end
                        local Btn = Create("TextButton", {
                            Parent = parent, Size = UDim2.new(1, 0, 1, 0),
                            BackgroundColor3 = Theme.SurfaceAlt, Text = label,
                            TextColor3 = Theme.TextPrimary, Font = Enum.Font.Gotham, TextSize = 11,
                            AutoButtonColor = false, ZIndex = 4,
                        })
                        AddCorner(Btn, 7); AddStroke(Btn, Theme.Border, 1)
                        Btn.MouseButton1Click:Connect(cb)
                        return Btn
                    end
                    function mini:AddToggle(label, default, cb)
                        cb = cb or function() end
                        local state = (default == true)
                        local lbl = Create("TextLabel", {
                            Parent = parent, Position = UDim2.new(0,0,0,0),
                            Size = UDim2.new(1,-36,1,0),
                            BackgroundTransparency=1, Text=label,
                            TextColor3=Theme.TextPrimary, Font=Enum.Font.Gotham, TextSize=11,
                            TextXAlignment=Enum.TextXAlignment.Left, ZIndex=4,
                        })
                        local Track = Create("Frame", {
                            Parent=parent, Position=UDim2.new(1,-34,0.5,-10),
                            Size=UDim2.new(0,32,0,18),
                            BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff, ZIndex=4,
                        })
                        AddCorner(Track, 999)
                        local Knob = Create("Frame", {
                            Parent=Track, Size=UDim2.new(0,12,0,12),
                            Position = state and UDim2.new(0,17,0.5,-6) or UDim2.new(0,3,0.5,-6),
                            BackgroundColor3=Color3.fromRGB(255,255,255), ZIndex=5,
                        })
                        AddCorner(Knob, 999)
                        local TB = Create("TextButton", {Parent=parent, Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Text="", ZIndex=6})
                        local function SS(v) state=v
                            Tween(Track,{BackgroundColor3=state and Theme.ToggleOn or Theme.ToggleOff},0.2)
                            Tween(Knob,{Position=state and UDim2.new(0,17,0.5,-6) or UDim2.new(0,3,0.5,-6)},0.2,Enum.EasingStyle.Back)
                            cb(state)
                        end
                        TB.MouseButton1Click:Connect(function() SS(not state) end)
                        return {Set=SS, Get=function() return state end}
                    end
                    return mini
                end
                leftFn(wrapMini(Left))
                rightFn(wrapMini(Right))
            end

            table.insert(tabData._sections, Section)
            return Section
        end

        return tabData
    end

