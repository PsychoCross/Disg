                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then hSliding = false end
                end)
                local SwatchBtn = Create("TextButton", {Parent = row, Size = UDim2.new(0, 34, 1, 0),
                    Position = UDim2.new(1, -36, 0, 0), BackgroundTransparency = 1, Text = "", ZIndex = 5,
