-- ============================================================
-- Utility
-- ============================================================
local function Tween(obj, props, t, style, dir)
    local i = TweenInfo.new(t or 0.2, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out)
    local tw = TweenService:Create(obj, i, props)
    tw:Play()
    return tw
end

local function Create(cls, props, children)
    local o = Instance.new(cls)
    for k, v in pairs(props or {}) do o[k] = v end
    for _, c in ipairs(children or {}) do c.Parent = o end
    return o
end

local function Corner(p, r)
    return Create("UICorner", {Parent = p, CornerRadius = UDim.new(0, r or 6)})
end

local function Stroke(p, col, thick, trans)
    return Create("UIStroke", {
        Parent = p, Color = col or Theme.BorderMid,
        Thickness = thick or 1, Transparency = trans or 0,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })
end

local function Pad(p, t, b, l, r)
    return Create("UIPadding", {
        Parent = p,
        PaddingTop    = UDim.new(0, t or 6),
        PaddingBottom = UDim.new(0, b or 6),
        PaddingLeft   = UDim.new(0, l or 8),
        PaddingRight  = UDim.new(0, r or 8),
    })
end

local function MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging, dragInput, dragStart, startPos
    handle.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = inp.Position
            startPos  = frame.Position
            inp.Changed:Connect(function()
                if inp.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragInput = inp
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if inp == dragInput and dragging then
            local d = inp.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)
end

local function RoundTo(v, dec)
    dec = dec or 0
    local f = 10 ^ dec
    return math.floor(v * f + 0.5) / f
end

-- Scanline overlay (gives that cheat-tool feel)
local function AddScanlines(parent, zIndex)
    local scan = Create("Frame", {
        Parent = parent, Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1, ZIndex = zIndex or 1,
        Name = "Scanlines",
    })
    -- Very subtle repeating lines using gradient
    Create("UIGradient", {
        Parent = scan,
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(0, 0, 0)),
            ColorSequenceKeypoint.new(0.49, Color3.fromRGB(0, 0, 0)),
            ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(20, 40, 30)),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(0, 0, 0)),
        }),
        Rotation = 90,
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0,   0.97),
            NumberSequenceKeypoint.new(0.49, 0.97),
            NumberSequenceKeypoint.new(0.5,  0.92),
            NumberSequenceKeypoint.new(1,   0.97),
        }),
    })
    return scan
end

