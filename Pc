            -- ==========================
            function Sec:AddSlider(label, min, max, default, callback, decimals, configKey)
                min = min or 0; max = max or 100; decimals = decimals or 0
                default = RoundTo(math.clamp(default or min, min, max), decimals)
                callback = callback or function() end
                local value = default
                local row = Row(46)

                local top = Create("Frame", {
                    Parent = row, Size = UDim2.new(1, 0, 0, 18),
                    BackgroundTransparency = 1, ZIndex = 6,
                })
                Create("TextLabel", {
                    Parent = top, Size = UDim2.new(0.7, 0, 1, 0),
                    BackgroundTransparency = 1, Text = label,
                    TextColor3 = Theme.TextBright, Font = Enum.Font.Code, TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6,
                })
                local ValLbl = Create("TextLabel", {
                    Parent = top, Position = UDim2.new(0.7, 0, 0, 0),
                    Size = UDim2.new(0.3, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = tostring(default),
                    TextColor3 = Theme.Accent, Font = Enum.Font.Code, TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 6,
                })

                local Track = Create("Frame", {
                    Parent = row, Position = UDim2.new(0, 0, 0, 24),
                    Size = UDim2.new(1, 0, 0, 6),
                    BackgroundColor3 = Theme.BG3, ZIndex = 6,
                })
                Corner(Track, 2)
                Stroke(Track, Theme.BorderDark, 1)

                local Fill = Create("Frame", {
                    Parent = Track,
                    Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
                    BackgroundColor3 = Theme.Accent, ZIndex = 7,
                })
                Corner(Fill, 2)
                Create("UIGradient", {
                    Parent = Fill,
                    Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Theme.AccentDim),
                        ColorSequenceKeypoint.new(1, Theme.AccentGlow),
                    }),
                })

                local Thumb = Create("Frame", {
                    Parent = Track, Size = UDim2.new(0, 10, 0, 14),
                    Position = UDim2.new((default - min) / (max - min), 0 - 5, 0.5, -7),
                    BackgroundColor3 = Theme.Accent, ZIndex = 8,
                })
                Corner(Thumb, 2)

                local Drag = Create("TextButton", {
                    Parent = Track, Size = UDim2.new(1, 0, 0, 22),
                    Position = UDim2.new(0, 0, 0.5, -11),
                    BackgroundTransparency = 1, Text = "", ZIndex = 9,
                })

                local sliding = false
                local function Update(ix)
                    local rel = math.clamp((ix - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    value = RoundTo(min + rel * (max - min), decimals)
                    ValLbl.Text = decimals > 0 and string.format("%." .. decimals .. "f", value) or tostring(value)
                    Tween(Fill,  {Size = UDim2.new(rel, 0, 1, 0)}, 0.04)
                    Tween(Thumb, {Position = UDim2.new(rel, 0 - 5, 0.5, -7)}, 0.04)
                    callback(value)
                end
                Drag.MouseButton1Down:Connect(function()
                    sliding = true
                    Update(UserInputService:GetMouseLocation().X)
                end)
                UserInputService.InputChanged:Connect(function(i)
                    if sliding and (i.UserInputType == Enum.UserInputType.MouseMovement
                                 or i.UserInputType == Enum.UserInputType.Touch) then
                        Update(i.Position.X)
                    end
                end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1
                    or i.UserInputType == Enum.UserInputType.Touch then
                        sliding = false
                    end
                end)

                local function Set(v)
                    v = RoundTo(math.clamp(v, min, max), decimals)
                    local rel = (v - min) / (max - min)
                    Update(Track.AbsolutePosition.X + rel * Track.AbsoluteSize.X)
                end
                local obj = {Value = value, Get = function() return value end, Set = Set}
                if configKey then
                    table.insert(Window._elements, {key = configKey, get = function() return value end, set = Set})
                end
                return obj
            end

