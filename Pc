-- ūüß© ASSET LOADER
-- DescarcńÉ o imagine de pe GitHub (HttpGet), o salveazńÉ local (writefile),
-- »ôi o converte»ôte √ģntr-un asset utilizabil de Roblox (getcustomasset),
-- FńāRńā sńÉ fie nevoie sńÉ o uploadezi manual pe Roblox ca rbxassetid.
-- Func»õioneazńÉ pe executoare care suportńÉ HttpGet + writefile + getcustomasset
-- (Delta, Synapse X, Script-Ware etc.). DacńÉ executorul nu suportńÉ una din
-- func»õii, se face fallback automat la un placeholder rbxassetid.
-- ============================================================
local FALLBACK_IMAGE = "rbxassetid://131583568098851" -- folosit dacńÉ descńÉrcarea e»ôueazńÉ

local AssetLoader = {}
AssetLoader._cache = {} -- url -> rbxasset://... (cache √ģn memorie, nu redescarcńÉ de 2 ori pe sesiune)

local ASSET_FOLDER = "ACTED/assets"

local function EnsureAssetFolder()
    pcall(function()
        if not isfolder("ACTED") then makefolder("ACTED") end
        if not isfolder(ASSET_FOLDER) then makefolder(ASSET_FOLDER) end
    end)
end

local function UrlToFileName(url)
    -- transformńÉ URL-ul √ģntr-un nume de fi»ôier sigur, pńÉstr√Ęnd extensia
    local ext = url:match("%.([%a%d]+)$") or "png"
    local hash = 0
    for i = 1, #url do hash = (hash * 31 + url:byte(i)) % 2147483647 end
    return ASSET_FOLDER .. "/" .. tostring(hash) .. "." .. ext
end

-- VerificńÉ ce func»õii sunt disponibile √ģn executorul curent
local SUPPORTS_CUSTOMASSET = typeof(getcustomasset) == "function"
local SUPPORTS_HTTPGET     = typeof(game.HttpGet) == "function" or typeof(HttpGet) == "function"
local SUPPORTS_FS          = typeof(writefile) == "function" and typeof(isfile) == "function"

-- Func»õie de download (sincronńÉ, apelatńÉ din coroutine/task.spawn ca sńÉ nu √ģnghe»õ UI-ul)
local function DownloadTo(url, path)
    local ok, data = pcall(function()
        if game.HttpGet then
            return game:HttpGet(url, true)
        elseif HttpGet then
            return HttpGet(url, true)
        end
        return nil
    end)
    if not ok then
        warn("[ACTED AssetLoader] HttpGet a e»ôuat pentru " .. url .. " -> " .. tostring(data))
        return false
    end
    if not data or #data == 0 then
        warn("[ACTED AssetLoader] HttpGet a √ģntors date goale pentru " .. url)
        return false
    end
    -- detectare rapidńÉ: dacńÉ GitHub a √ģntors o paginńÉ HTML (404 / link gre»ôit) √ģn loc de imagine
    if data:sub(1, 15):find("<") then
        warn("[ACTED AssetLoader] URL-ul nu pare sńÉ fie o imagine validńÉ (pare HTML/404): " .. url)
        return false
    end
    local ok2, err2 = pcall(writefile, path, data)
    if not ok2 then
        warn("[ACTED AssetLoader] writefile a e»ôuat pentru " .. path .. " -> " .. tostring(err2))
    end
    return ok2
end

-- ReturneazńÉ un Image valid IMEDIAT (placeholder), apoi apeleazńÉ callback(realImage)
-- c√Ęnd descńÉrcarea s-a terminat. A»ôa nu blochezi construc»õia UI-ului.
function AssetLoader.Get(url, callback)
    if not url or url == "" then
        if callback then callback(FALLBACK_IMAGE) end
        return FALLBACK_IMAGE
    end

    if AssetLoader._cache[url] then
        if callback then callback(AssetLoader._cache[url]) end
        return AssetLoader._cache[url]
    end

    if not (SUPPORTS_HTTPGET and SUPPORTS_FS and SUPPORTS_CUSTOMASSET) then
        -- Executorul nu suportńÉ asset loading custom -> fallback direct
        warn("[ACTED AssetLoader] Executorul nu suportńÉ HttpGet/writefile/getcustomasset. Se folose»ôte fallback pentru: " .. url)
        AssetLoader._cache[url] = FALLBACK_IMAGE
        if callback then callback(FALLBACK_IMAGE) end
        return FALLBACK_IMAGE
    end

    EnsureAssetFolder()
    local path = UrlToFileName(url)

    task.spawn(function()
        local finalImage = FALLBACK_IMAGE
        local needsDownload = true
        pcall(function() needsDownload = not isfile(path) end)

        if needsDownload then
            local success = DownloadTo(url, path)
            if not success then
                AssetLoader._cache[url] = FALLBACK_IMAGE
                if callback then callback(FALLBACK_IMAGE) end
                return
            end
        end

        local ok, asset = pcall(getcustomasset, path)
        if ok and asset then
            finalImage = asset
        else
            warn("[ACTED AssetLoader] getcustomasset a e»ôuat pentru " .. path .. " -> " .. tostring(asset))
        end
        AssetLoader._cache[url] = finalImage
        if callback then callback(finalImage) end
    end)

    return FALLBACK_IMAGE -- placeholder instant, √ģnlocuit de callback
end

-- AplicńÉ direct pe un ImageLabel/ImageButton: seteazńÉ placeholder, apoi swap cu fade
function AssetLoader.Apply(imageObj, url)
    if not imageObj then return end
    AssetLoader.Get(url, function(realImage)
        if not imageObj or not imageObj.Parent then return end
        imageObj.ImageTransparency = 1
        imageObj.Image = realImage
        TweenService:Create(imageObj, TweenInfo.new(0.35), {ImageTransparency = 0}):Play()
    end)
end

