                    CPFrame.Visible = true
                    Tween(CPFrame, {Size = UDim2.new(0, 160, 0, CPOpen and 56 or 0)}, 0.2, Enum.EasingStyle.Back)
                    if not CPOpen then task.delay(0.22, function() CPFrame.Visible = false end) end
                end)
                UpdateColor()
                local function GetColor() return Color3.fromHSV(hue, sat, val_cp) end
                local obj = {Get = GetColor}
                if configKey then table.insert(Window._elements, {key = configKey,
                    get = function() local c = GetColor(); return {r = c.R, g = c.G, b = c.B} end,
                    set = function(v)
                        if type(v) == "table" then
                            local col = Color3.new(v.r, v.g, v.b)
                            hue, sat, val_cp = Color3.toHSV(col); UpdateColor()
                        end
                    end}) end
                return obj
            end

            -- ── LABEL ───────────────────────────────────────────
            function Section:AddLabel(text, color)
                local row = MakeRow(20)
                Create("TextLabel", {Parent = row, Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1, Text = text,
                    TextColor3 = color or Theme.TextSecondary,
                    Font = Enum.Font.Gotham, TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4, TextWrapped = true,
                })
            end

            -- ── KEYBIND ─────────────────────────────────────────
            function Section:AddKeybind(label, default, callback, configKey)
                callback = callback or function() end
                default  = default  or Enum.KeyCode.RightShift
                local key = default; local listening = false
                local row = MakeRow(34)
                Create("TextLabel", {Parent = row, Size = UDim2.new(0.6, 0, 1, 0),
                    BackgroundTransparency = 1, Text = label,
                    TextColor3 = Theme.TextPrimary, Font = Enum.Font.Gotham, TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
                })
                local KBtn = Create("TextButton", {Parent = row, Position = UDim2.new(0.62, 0, 0.1, 0),
                    Size = UDim2.new(0.38, 0, 0.8, 0), BackgroundColor3 = Theme.Surface,
                    Text = "[" .. tostring(key.Name) .. "]",
                    TextColor3 = Theme.Accent, Font = Enum.Font.GothamSemibold,
                    TextSize = 11, AutoButtonColor = false, ZIndex = 4,
                })
                AddCorner(KBtn, 7); AddStroke(KBtn, Theme.Border, 1)
                KBtn.MouseButton1Click:Connect(function() listening = true; KBtn.Text = "[...]"; KBtn.TextColor3 = Theme.Warning end)
                UserInputService.InputBegan:Connect(function(inp)
                    if listening and inp.UserInputType == Enum.UserInputType.Keyboard then
                        key = inp.KeyCode; KBtn.Text = "[" .. tostring(key.Name) .. "]"
                        KBtn.TextColor3 = Theme.Accent; listening = false
                    end
                    if not listening and inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == key then
                        callback(key)
                    end
                end)
                local obj = {Get = function() return key end}
                if configKey then table.insert(Window._elements, {key = configKey,
                    get = function() return key.Name end,
                    set = function(v) local ok, kc = pcall(function() return Enum.KeyCode[v] end)
                        if ok and kc then key = kc; KBtn.Text = "[" .. v .. "]" end end}) end
                return obj
            end

            -- ── DIVIDER ─────────────────────────────────────────
            function Section:AddDivider()
                local row = MakeRow(10)
                Create("Frame", {Parent = row, Size = UDim2.new(1, 0, 0, 1),
                    Position = UDim2.new(0, 0, 0.5, 0),
                    BackgroundColor3 = Theme.Border, BorderSizePixel = 0, ZIndex = 4,
                })
            end

            table.insert(tabData._sections, Section)
            return Section
        end

        return tabData
    end

    -- ============================================================
    -- Notifications
    -- ============================================================
    function Window:Notify(title, message, ntype, duration)
        ntype = ntype or "info"; duration = duration or 3
        local colors = {info = Theme.Accent, success = Theme.Success, warning = Theme.Warning, error = Theme.Danger}
        local icons  = {info = "i", success = "✓", warning = "!", error = "✕"}
        local col = colors[ntype] or Theme.Accent
        local icon = icons[ntype] or "i"

        local NHolder = ScreenGui:FindFirstChild("ACTED_NH")
        if not NHolder then
            NHolder = Create("Frame", {Name = "ACTED_NH", Parent = ScreenGui,
                Position = UDim2.new(1, -340, 1, -40),
                Size = UDim2.new(0, 320, 0, 0),
                BackgroundTransparency = 1, ZIndex = 200,
            })
            Create("UIListLayout", {Parent = NHolder,
                VerticalAlignment = Enum.VerticalAlignment.Bottom,
                HorizontalAlignment = Enum.HorizontalAlignment.Right,
                SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 10),
            })
        end

        local NWrap = Create("Frame", {Parent = NHolder,
            Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1,
            ClipsDescendants = true, ZIndex = 200,
        })
        local NFrame = Create("Frame", {Parent = NWrap,
            Size = UDim2.new(1, 0, 0, 80),
            Position = UDim2.new(0, 330, 0, 0),
            BackgroundColor3 = Theme.Surface,
            BackgroundTransparency = 0.04, ZIndex = 200,
        })
        AddCorner(NFrame, 12)
        AddStroke(NFrame, col, 1.2, 0.1)

        -- Accent left bar
        local NBar = Create("Frame", {Parent = NFrame,
            Size = UDim2.new(0, 3, 0.6, 0), Position = UDim2.new(0, 12, 0.2, 0),
            BackgroundColor3 = col, BorderSizePixel = 0, ZIndex = 201,
        })
        AddCorner(NBar, 2)

        -- Icon circle
        local IconF = Create("Frame", {Parent = NFrame,
            Position = UDim2.new(0, 22, 0.5, -16), Size = UDim2.new(0, 32, 0, 32),
            BackgroundColor3 = Theme.SurfaceAlt, ZIndex = 201,
        })
        AddCorner(IconF, 16)
        AddStroke(IconF, col, 1, 0.2)
        Create("TextLabel", {Parent = IconF, Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1, Text = icon,
            TextColor3 = col, Font = Enum.Font.GothamBlack, TextSize = 14, ZIndex = 202,
        })

        -- Text
        local TH = Create("Frame", {Parent = NFrame, Position = UDim2.new(0, 66, 0, 0),
            Size = UDim2.new(1, -80, 1, -10), BackgroundTransparency = 1, ZIndex = 201,
        })
        Create("UIListLayout", {Parent = TH, VerticalAlignment = Enum.VerticalAlignment.Center,
            SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 3),
        })
        Create("TextLabel", {Parent = TH, Size = UDim2.new(1, 0, 0, 16),
            BackgroundTransparency = 1, Text = title,
            TextColor3 = Theme.TextPrimary, Font = Enum.Font.GothamBold, TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 201,
        })
        Create("TextLabel", {Parent = TH, Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1, Text = message,
            TextColor3 = Theme.TextSecondary, Font = Enum.Font.Gotham, TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true, AutomaticSize = Enum.AutomaticSize.Y, ZIndex = 201,
        })

        -- Progress bar
        local PBG = Create("Frame", {Parent = NFrame, Size = UDim2.new(1, -24, 0, 2),
            Position = UDim2.new(0, 12, 1, -7),
            BackgroundColor3 = Theme.SurfaceAlt, BorderSizePixel = 0, ZIndex = 201,
        })
        AddCorner(PBG, 2)
        local PFill = Create("Frame", {Parent = PBG, Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = col, BorderSizePixel = 0, ZIndex = 202,
        })
        AddCorner(PFill, 2)

        -- Slide in
        Tween(NWrap, {Size = UDim2.new(1, 0, 0, 80)}, 0.38, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
        task.delay(0.05, function()
            Tween(NFrame, {Position = UDim2.new(0, 0, 0, 0)}, 0.42, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
        end)
        Tween(PFill, {Size = UDim2.new(0, 0, 1, 0)}, duration, Enum.EasingStyle.Linear)

        task.delay(duration, function()
            Tween(NFrame, {Position = UDim2.new(0, 330, 0, 0), BackgroundTransparency = 1}, 0.35, Enum.EasingStyle.Exponential, Enum.EasingDirection.In)
            task.delay(0.36, function()
                Tween(NWrap, {Size = UDim2.new(1, 0, 0, 0)}, 0.28, Enum.EasingStyle.Exponential)
                task.delay(0.3, function() NWrap:Destroy() end)
            end)
        end)
    end

    task.delay(0.7, function()
        Window:Notify("ACTED", "Hub loaded successfully.", "success", 3)
    end)

    return Window
end

return ACTED
