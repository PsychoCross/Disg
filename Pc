    -- ============================================================
    -- Window Object
    -- ============================================================
    local Window    = {}
    Window._tabs     = {}
    Window._elements = {}

    local function SerializeConfig()
        local d = {}
        for _, el in ipairs(Window._elements) do d[el.key] = el.get() end
        local ok, j = pcall(function() return HttpService:JSONEncode(d) end)
        return ok and j or nil
    end
    local function ApplyConfig(json)
        local ok, d = pcall(function() return HttpService:JSONDecode(json) end)
        if not ok or type(d) ~= "table" then return false end
        for _, el in ipairs(Window._elements) do
            if d[el.key] ~= nil then pcall(function() el.set(d[el.key]) end) end
        end
        return true
    end

    function Window:SaveConfig(n)
        EnsureFolders(); n = n or "default"
        local j = SerializeConfig()
        if not j then Window:Notify("CFG", "Serialization failed", "error", 3); return end
        local ok = false
        pcall(function() writefile(SettingFileName(n), j); AddSettingToList(n); ok = true end)
        if ok then Window:Notify("CFG", "Saved: " .. n .. ".cfg", "success", 3)
        else       Window:Notify("CFG", "Console fallback (no writefile)", "warning", 3) end
        return j
    end
    function Window:LoadConfig(n, raw)
        EnsureFolders(); n = n or "default"
        local j = raw
        if not j then
            local ok, c = pcall(readfile, SettingFileName(n))
            if ok and c then j = c
            else Window:Notify("CFG", "Not found: " .. n .. ".cfg", "error", 3); return end
        end
        if ApplyConfig(j) then Window:Notify("CFG", "Loaded: " .. n .. ".cfg", "success", 3)
        else                    Window:Notify("CFG", "Invalid config data", "error", 3) end
    end
    function Window:DeleteConfig(n)
        EnsureFolders(); n = n or "default"
        pcall(function() delfile(SettingFileName(n)) end)
        RemoveSettingFromList(n)
        Window:Notify("CFG", "Deleted: " .. n .. ".cfg", "info", 3)
    end

    -- ============================================================
    -- Config Manager Section
    -- ============================================================
    function Window:AddConfigManager(section)
        section:AddLabel("// CONFIG MANAGER", Theme.Accent)
        section:AddDivider()
        local nameBox     = section:AddTextbox("Config name", "my_config", "", function() end)
        local settingList = ReadSettingList()
        local selected    = nil
        local ddObj, alToggle
        local autoData = ReadAutoLoad()
        if autoData.enabled and autoData.setting then
            for _, v in ipairs(settingList) do
                if v == autoData.setting then selected = v; break end
            end
        end
        local function Refresh()
            settingList = ReadSettingList()
            local found = false
            for _, v in ipairs(settingList) do if v == selected then found = true; break end end
            if not found then selected = nil end
            if ddObj then ddObj.SetOptions(settingList, selected) end
        end
        ddObj = section:AddDropdown("Active config", settingList, selected, function(v)
            selected = v
            if alToggle and alToggle.Get() then
                WriteAutoLoad(true, selected)
            end
        end)
        alToggle = section:AddToggle("Auto-load on start", autoData.enabled, function(state)
            if state and (not selected or selected == "") then
                Window:Notify("CFG", "Select a config first", "warning", 3)
                alToggle.Set(false); WriteAutoLoad(false, nil); return
            end
            WriteAutoLoad(state, state and selected or nil)
            Window:Notify("CFG", state and ("Auto-load: " .. tostring(selected)) or "Auto-load off", state and "success" or "info", 3)
        end)
        section:AddButton("Save", function()
            local n = nameBox.Get()
            if not n or n == "" then n = selected end
            if not n or n == "" then Window:Notify("CFG", "Enter a config name", "warning", 3); return end
            Window:SaveConfig(n); Refresh()
        end)
        section:AddButton("Load selected", function()
            if not selected or selected == "" then Window:Notify("CFG", "Select a config first", "warning", 3); return end
            Window:LoadConfig(selected)
        end)
        section:AddButton("Delete selected", function()
            if not selected or selected == "" then Window:Notify("CFG", "Select a config first", "warning", 3); return end
            Window:DeleteConfig(selected)
            local al = ReadAutoLoad()
            if al.enabled and al.setting == selected then WriteAutoLoad(false, nil); if alToggle then alToggle.Set(false) end end
            selected = nil; Refresh()
        end)
        section:AddButton("Refresh list", function() Refresh(); Window:Notify("CFG", "List refreshed", "info", 2) end)
        section:AddDivider()
        if autoData.enabled and autoData.setting then
            local target = autoData.setting
            local exists = false
            for _, v in ipairs(ReadSettingList()) do if v == target then exists = true; break end end
            if exists then
                task.delay(0.8, function()
                    Window:LoadConfig(target)
                    selected = target
                    if ddObj then ddObj.SetOptions(ReadSettingList(), target) end
                end)
            else
                WriteAutoLoad(false, nil)
                if alToggle then alToggle.Set(false) end
            end
        end
