            -- ── DROPDOWN ────────────────────────────────────────
            function Section:AddDropdown(label, options, default, callback, configKey)
                callback = callback or function() end
                options  = options  or {}
                local selected = default
                local open     = false
                local renderConn = nil
                local row = MakeRow(34)

                Create("TextLabel", {Parent = row, Size = UDim2.new(0.5, 0, 1, 0),
                    BackgroundTransparency = 1, Text = label,
                    TextColor3 = Theme.TextPrimary, Font = Enum.Font.Gotham, TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
                })
                local function BtnLabel() return (selected or "Select...") .. "  ▾" end
                local DDBtn = Create("TextButton", {Parent = row,
                    Position = UDim2.new(0.45, 0, 0.1, 0), Size = UDim2.new(0.55, 0, 0.8, 0),
                    BackgroundColor3 = Theme.SurfaceAlt,
                    Text = BtnLabel(),
                    TextColor3 = selected and Theme.TextPrimary or Theme.TextDim,
                    Font = Enum.Font.Gotham, TextSize = 11,
                    AutoButtonColor = false, ZIndex = 4,
                })
                AddCorner(DDBtn, 7)
                local ddStroke = AddStroke(DDBtn, Theme.Border, 1)

                local Overlay = Create("TextButton", {Parent = ScreenGui,
                    Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
                    Text = "", ZIndex = 49, Visible = false, AutoButtonColor = false,
                })
                local DDList = Create("ScrollingFrame", {Parent = ScreenGui,
                    Size = UDim2.new(0, 0, 0, 0), BackgroundColor3 = Theme.SurfaceAlt,
                    Visible = false, ZIndex = 50, ClipsDescendants = true,
                    ScrollBarThickness = 3, ScrollBarImageColor3 = Theme.Accent,
                    CanvasSize = UDim2.new(0, 0, 0, 0),
                    AutomaticCanvasSize = Enum.AutomaticSize.Y,
                    BorderSizePixel = 0,
                })
                AddCorner(DDList, 8)
                AddStroke(DDList, Theme.BorderActive, 1)
                Create("UIListLayout", {Parent = DDList, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2)})
                AddPadding(DDList, 4, 4, 4, 4)

                local function CloseDD()
                    if not open then return end
                    open = false
                    if renderConn then renderConn:Disconnect(); renderConn = nil end
                    if _openDropdown and _openDropdown.list == DDList then _openDropdown = nil end
                    Overlay.Visible = false; DDList.Visible = false
                    DDList.Size = UDim2.new(0, DDList.Size.X.Offset, 0, 0)
                    DDBtn.Text = BtnLabel()
                end
                Overlay.MouseButton1Click:Connect(CloseDD)

                local function BuildOptions(optList)
                    for _, c in ipairs(DDList:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                    for _, opt in ipairs(optList) do
                        local OB = Create("TextButton", {Parent = DDList, Size = UDim2.new(1, 0, 0, 26),
                            BackgroundColor3 = Theme.Surface, Text = opt,
                            TextColor3 = (opt == selected) and Theme.AccentBright or Theme.TextPrimary,
                            Font = Enum.Font.Gotham, TextSize = 12, AutoButtonColor = false, ZIndex = 51,
                        })
                        AddCorner(OB, 6)
                        OB.MouseEnter:Connect(function() Tween(OB, {BackgroundColor3 = Theme.SurfaceHover}, 0.1) end)
                        OB.MouseLeave:Connect(function() Tween(OB, {BackgroundColor3 = Theme.Surface}, 0.1) end)
                        OB.MouseButton1Click:Connect(function()
                            selected = opt
                            DDBtn.Text = BtnLabel(); DDBtn.TextColor3 = Theme.TextPrimary
                            for _, c2 in ipairs(DDList:GetChildren()) do
                                if c2:IsA("TextButton") then
                                    c2.TextColor3 = (c2.Text == selected) and Theme.AccentBright or Theme.TextPrimary
                                end
                            end
                            CloseDD(); callback(selected)
                        end)
                    end
                end
                BuildOptions(options)

                local function OpenDD()
                    if _openDropdown then _openDropdown.close() end
                    open = true; _openDropdown = {close = CloseDD, list = DDList}
                    local btnSize = DDBtn.AbsoluteSize
                    local targetH = math.min(#options * 30 + 12, 180)
                    DDList.Size = UDim2.new(0, btnSize.X, 0, 0)
                    DDList.Visible = true; Overlay.Visible = true
                    renderConn = RunService.RenderStepped:Connect(function()
                        local ap = DDBtn.AbsolutePosition
                        local hub_b = Main.AbsolutePosition.Y + Main.AbsoluteSize.Y
                        local below = hub_b - (ap.Y + btnSize.Y)
                        local isUp = below < targetH
                        local ch = DDList.AbsoluteSize.Y
                        local ty = isUp and (ap.Y - ch - 4) or (ap.Y + btnSize.Y + 4)
                        DDList.Position = UDim2.new(0, ap.X, 0, ty)
                    end)
                    Tween(DDList, {Size = UDim2.new(0, btnSize.X, 0, targetH)}, 0.2, Enum.EasingStyle.Back)
                    DDBtn.Text = (selected or "Select...") .. "  ▴"
                end

                DDBtn.MouseButton1Click:Connect(function() if open then CloseDD() else OpenDD() end end)
                DDBtn.MouseEnter:Connect(function() Tween(ddStroke, {Color = Theme.BorderActive}, 0.15) end)
                DDBtn.MouseLeave:Connect(function() Tween(ddStroke, {Color = Theme.Border}, 0.15) end)

                local ddObj = {
                    Value = selected, Get = function() return selected end,
                    Set = function(v) selected = v; DDBtn.Text = BtnLabel(); DDBtn.TextColor3 = selected and Theme.TextPrimary or Theme.TextDim; callback(v) end,
                    SetOptions = function(newOpts, keepSelected)
                        options = newOpts or {}
                        local valid = false
                        for _, v in ipairs(options) do if v == keepSelected then valid = true; break end end
                        selected = valid and keepSelected or nil
                        DDBtn.Text = BtnLabel(); DDBtn.TextColor3 = selected and Theme.TextPrimary or Theme.TextDim
                        BuildOptions(options)
                    end,
                }
                if configKey then table.insert(Window._elements, {key = configKey,
                    get = function() return selected end, set = ddObj.Set}) end
                return ddObj
            end

