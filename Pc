                })
                local Swatch = Create("Frame", {
                    Parent = row, Position = UDim2.new(1, -34, 0.18, 0),
                    Size = UDim2.new(0, 28, 0.64, 0),
                    BackgroundColor3 = default, ZIndex = 4,
                })
                AddCorner(Swatch, 5)
                AddStroke(Swatch, Theme.Border, 1)

                local hue, sat, val_cp = Color3.toHSV(default)
                local CPOpen = false
                local CPFrame = Create("Frame", {
                    Parent = ScreenGui, Size = UDim2.new(0, 160, 0, 0),
                    BackgroundColor3 = Theme.Surface, Visible = false, ZIndex = 50,
                    ClipsDescendants = true,
                })
                AddCorner(CPFrame, 10)
                AddStroke(CPFrame, Theme.Accent, 1.2)

                local HueTrack = Create("Frame", {
                    Parent = CPFrame, Position = UDim2.new(0, 8, 0, 10),
                    Size = UDim2.new(1, -16, 0, 14),
                    ZIndex = 51,
                })
                AddCorner(HueTrack, 999)
                Create("UIGradient", {Parent = HueTrack, Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0,   Color3.fromHSV(0,   1, 1)),
                    ColorSequenceKeypoint.new(1/6, Color3.fromHSV(1/6, 1, 1)),
                    ColorSequenceKeypoint.new(2/6, Color3.fromHSV(2/6, 1, 1)),
                    ColorSequenceKeypoint.new(3/6, Color3.fromHSV(3/6, 1, 1)),
                    ColorSequenceKeypoint.new(4/6, Color3.fromHSV(4/6, 1, 1)),
                    ColorSequenceKeypoint.new(5/6, Color3.fromHSV(5/6, 1, 1)),
                    ColorSequenceKeypoint.new(1,   Color3.fromHSV(1,   1, 1)),
                })})
                local HueThumb = Create("Frame", {
                    Parent = HueTrack, Size = UDim2.new(0, 10, 0, 18),
                    Position = UDim2.new(hue, -5, 0.5, -9),
                    BackgroundColor3 = Color3.fromRGB(255,255,255), ZIndex = 52,
                })
                AddCorner(HueThumb, 999)

                local function UpdateColor()
                    local col = Color3.fromHSV(hue, sat, val_cp)
                    Swatch.BackgroundColor3 = col
                    HueThumb.Position = UDim2.new(hue, -5, 0.5, -9)
                    callback(col)
                end

                local hSliding = false
                local HueDrag = Create("TextButton", {
                    Parent = HueTrack, Size = UDim2.new(1, 0, 0, 24),
                    Position = UDim2.new(0,0,0.5,-12), BackgroundTransparency = 1, Text = "", ZIndex = 53,
                })
                HueDrag.MouseButton1Down:Connect(function() hSliding = true end)
                UserInputService.InputChanged:Connect(function(inp)
                    if hSliding and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
                        hue = math.clamp((inp.Position.X - HueTrack.AbsolutePosition.X) / HueTrack.AbsoluteSize.X, 0, 1)
                        UpdateColor()
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then hSliding = false end
                end)

                local SwatchBtn = Create("TextButton", {
                    Parent = row, Size = UDim2.new(0, 32, 1, 0),
                    Position = UDim2.new(1, -34, 0, 0),
                    BackgroundTransparency = 1, Text = "", ZIndex = 5,
                })
                SwatchBtn.MouseButton1Click:Connect(function()
                    CPOpen = not CPOpen
                    local ap = Swatch.AbsolutePosition
                    CPFrame.Position = UDim2.new(0, ap.X - 120, 0, ap.Y + 24)
                    CPFrame.Visible = true
                    Tween(CPFrame, {Size = UDim2.new(0, 160, 0, CPOpen and 52 or 0)}, 0.2, Enum.EasingStyle.Back)
                    if not CPOpen then task.delay(0.22, function() CPFrame.Visible = false end) end
                end)

                UpdateColor()
                local function GetColor() return Color3.fromHSV(hue, sat, val_cp) end
                local obj = {Get = GetColor}
                if configKey then
                    table.insert(Window._elements, {key = configKey,
                        get = function() local c = GetColor(); return {r=c.R, g=c.G, b=c.B} end,
                        set = function(v)
                            if type(v) == "table" then
                                local col = Color3.new(v.r, v.g, v.b)
                                hue, sat, val_cp = Color3.toHSV(col); UpdateColor()
                            end
                        end})
                end
                return obj
            end

            -- ===========================
            -- LABEL
            -- ===========================
            function Section:AddLabel(text, color)
                local row = MakeRow(20)
                Create("TextLabel", {
