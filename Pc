-- Config management & Folder System
-- ============================================================
local HUB_FOLDER    = "ACTED"
local CONFIG_FOLDER = HUB_FOLDER .. "/configs"
local META_FOLDER   = HUB_FOLDER .. "/meta"
local META_FILE     = META_FOLDER .. "/ACTED_configs.json"
local AUTOLOAD_FILE = META_FOLDER .. "/ACTED_autoload.json"

local function EnsureFolders()
    pcall(function()
        if not isfolder(HUB_FOLDER)    then makefolder(HUB_FOLDER)    end
        if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end
        if not isfolder(META_FOLDER)   then makefolder(META_FOLDER)   end
    end)
end

local function ConfigFileName(configName)
    return CONFIG_FOLDER .. "/" .. configName .. ".cfg"
end

local function ReadConfigList()
    EnsureFolders()
    local ok, raw = pcall(readfile, META_FILE)
    if not ok or not raw then return {} end
    local ok2, data = pcall(function()
        return HttpService:JSONDecode(raw)
    end)
    if ok2 and type(data) == "table" then return data end
    return {}
end

local function WriteConfigList(list)
    EnsureFolders()
    local ok, json = pcall(function()
        return HttpService:JSONEncode(list)
    end)
    if ok then pcall(writefile, META_FILE, json) end
end

local function AddConfigToList(configName)
    local list = ReadConfigList()
    for _, v in ipairs(list) do
        if v == configName then return end
    end
    table.insert(list, configName)
    WriteConfigList(list)
end

local function RemoveConfigFromList(configName)
    local list = ReadConfigList()
    local newList = {}
    for _, v in ipairs(list) do
        if v ~= configName then table.insert(newList, v) end
    end
    WriteConfigList(newList)
end

local function ReadAutoLoad()
    EnsureFolders()
    local ok, raw = pcall(readfile, AUTOLOAD_FILE)
    if not ok or not raw then return {enabled = false, config = nil} end
    local ok2, data = pcall(function()
        return HttpService:JSONDecode(raw)
    end)
    if ok2 and type(data) == "table" then
        return {enabled = data.enabled == true, config = data.config}
    end
    return {enabled = false, config = nil}
end

local function WriteAutoLoad(enabled, configName)
    EnsureFolders()
    local ok, json = pcall(function()
        return HttpService:JSONEncode({enabled = enabled, config = configName})
    end)
    if ok then pcall(writefile, AUTOLOAD_FILE, json) end
end

