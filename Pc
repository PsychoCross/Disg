    -- ============================================================
    -- Window object
    -- ============================================================
    local Window = {}
    Window._tabs      = {}
    Window._activeTab = nil
    Window._elements  = {}

    local function SerializeConfig()
        local data = {}
        for _, el in ipairs(Window._elements) do
            data[el.key] = el.get()
        end
        local ok, json = pcall(function()
            return HttpService:JSONEncode(data)
        end)
        if ok then return json end
        return nil
    end

    local function ApplyConfig(json)
        local ok, data = pcall(function()
            return HttpService:JSONDecode(json)
        end)
        if not ok or type(data) ~= "table" then return false end
        for _, el in ipairs(Window._elements) do
            if data[el.key] ~= nil then
                pcall(function() el.set(data[el.key]) end)
            end
        end
        return true
    end

    function Window:SaveConfig(configName)
        EnsureFolders()
        configName = configName or "default"
        local json = SerializeConfig()
        if not json then
            Window:Notify("Config", "Serialization failed.", "error", 3)
            return
        end
        local saved = false
        pcall(function()
            writefile(ConfigFileName(configName), json)
            AddConfigToList(configName)
            saved = true
        end)
        if saved then
            Window:Notify("Config", "Saved config: " .. configName .. ".cfg", "success", 3)
        else
            print("[ACTED Config Save] " .. configName .. ":\n" .. json)
            Window:Notify("Config", "Saved to console (no writefile).", "warning", 3)
        end
        return json
    end

    function Window:LoadConfig(configName, jsonString)
        EnsureFolders()
        configName = configName or "default"
        local json = jsonString
        if not json then
            local ok, content = pcall(readfile, ConfigFileName(configName))
            if ok and content then
                json = content
            else
                Window:Notify("Config", "File not found: " .. configName .. ".cfg", "error", 3)
                return
            end
        end
        if ApplyConfig(json) then
            Window:Notify("Config", "Loaded config: " .. configName .. ".cfg", "success", 3)
        else
            Window:Notify("Config", "Load failed: invalid data.", "error", 3)
        end
    end

    function Window:DeleteConfig(configName)
        EnsureFolders()
        configName = configName or "default"
        pcall(function() delfile(ConfigFileName(configName)) end)
        RemoveConfigFromList(configName)
        Window:Notify("Config", "Deleted config: " .. configName .. ".cfg", "info", 3)
    end

    function Window:AddConfigManager(section)
        section:AddLabel("CONFIG MANAGER", Theme.Accent)
        section:AddDivider()

        local nameBox = section:AddTextbox("Config name", "Enter config name...", "", function() end)
        local configList = ReadConfigList()
        local selectedConfig = nil
        local configDropdown = nil
        local autoLoadToggle = nil
        local autoLoadData = ReadAutoLoad()

        if autoLoadData.enabled and autoLoadData.config then
            for _, v in ipairs(configList) do
                if v == autoLoadData.config then selectedConfig = v; break end
            end
        end

        local function RefreshDropdown()
            configList = ReadConfigList()
            if configDropdown then
                local found = false
                for _, v in ipairs(configList) do
                    if v == selectedConfig then found = true; break end
                end
                if not found then selectedConfig = nil end
                configDropdown.SetOptions(configList, selectedConfig)
            end
        end

        configDropdown = section:AddDropdown("Select config", configList, selectedConfig, function(v)
            selectedConfig = v
            if autoLoadToggle and autoLoadToggle.Get() then
                WriteAutoLoad(true, selectedConfig)
                Window:Notify("Auto Load", "Now auto-loading: " .. tostring(selectedConfig) .. ".cfg", "info", 3)
            end
        end)

        autoLoadToggle = section:AddToggle("Auto Load Config", autoLoadData.enabled, function(state)
            if state then
                if not selectedConfig or selectedConfig == "" then
                    Window:Notify("Auto Load", "Select a config first.", "warning", 3)
                    autoLoadToggle.Set(false)
                    WriteAutoLoad(false, nil)
                    return
                end
                WriteAutoLoad(true, selectedConfig)
                Window:Notify("Auto Load", "Enabled for: " .. tostring(selectedConfig) .. ".cfg", "success", 3)
            else
                WriteAutoLoad(false, nil)
                Window:Notify("Auto Load", "Auto load disabled.", "info", 3)
            end
        end)

        section:AddButton("Save config", function()
            local name = nameBox.Get()
            if not name or name == "" then name = selectedConfig end
            if not name or name == "" then
                Window:Notify("Config", "Type a config name first.", "warning", 3)
                return
            end
            Window:SaveConfig(name)
            RefreshDropdown()
        end)

        section:AddButton("Load selected config", function()
            local name = selectedConfig
            if not name or name == "" then
                Window:Notify("Config", "Select a config from the dropdown.", "warning", 3)
                return
            end
            Window:LoadConfig(name)
        end)

        section:AddButton("Delete selected config", function()
            local name = selectedConfig
            if not name or name == "" then
                Window:Notify("Config", "Select a config to delete.", "warning", 3)
                return
            end
            Window:DeleteConfig(name)
            local al = ReadAutoLoad()
            if al.enabled and al.config == name then
                WriteAutoLoad(false, nil)
                if autoLoadToggle then autoLoadToggle.Set(false) end
            end
            selectedConfig = nil
            RefreshDropdown()
        end)

        section:AddButton("Refresh config list", function()
            RefreshDropdown()
            Window:Notify("Config", "Config list refreshed.", "info", 2)
        end)

        section:AddDivider()

        if autoLoadData.enabled and autoLoadData.config then
            local targetConfig = autoLoadData.config
            local exists = false
            for _, v in ipairs(ReadConfigList()) do
                if v == targetConfig then exists = true; break end
            end
            if exists then
                task.delay(0.8, function()
                    Window:LoadConfig(targetConfig)
                    selectedConfig = targetConfig
                    configDropdown.SetOptions(ReadConfigList(), targetConfig)
                end)
            else
                WriteAutoLoad(false, nil)
                if autoLoadToggle then autoLoadToggle.Set(false) end
            end
        end
    end

