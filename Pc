                local function Ripple(x, y)
                    local rip = Create("Frame", {
                        Parent = Btn, ZIndex = 7,
                        BackgroundColor3 = Theme.Accent, BackgroundTransparency = 0.6,
                        Size = UDim2.new(0, 0, 0, 0),
                        Position = UDim2.new(0, x - Btn.AbsolutePosition.X, 0, y - Btn.AbsolutePosition.Y),
                    })
                    AddCorner(rip, 999)
                    Tween(rip, {
                        Size = UDim2.new(0, 180, 0, 180),
                        Position = UDim2.new(0, x - Btn.AbsolutePosition.X - 90, 0, y - Btn.AbsolutePosition.Y - 90),
                        BackgroundTransparency = 1,
                    }, 0.5)
                    task.delay(0.5, function() rip:Destroy() end)
                end

                Btn.MouseEnter:Connect(function()
                    Tween(Btn, {BackgroundColor3 = Theme.SurfaceHover}, 0.12)
                    Tween(bStroke, {Color = Theme.BorderActive}, 0.15)
                    local icon_ = BInner:FindFirstChild("BtnIcon")
                    if icon_ then Tween(icon_, {ImageColor3 = Theme.AccentBright}, 0.12) end
                end)
                Btn.MouseLeave:Connect(function()
                    Tween(Btn, {BackgroundColor3 = Theme.SurfaceAlt}, 0.12)
                    Tween(bStroke, {Color = Theme.Border}, 0.15)
                    local icon_ = BInner:FindFirstChild("BtnIcon")
                    if icon_ then Tween(icon_, {ImageColor3 = Theme.TextSecondary}, 0.12) end
                end)
                Btn.MouseButton1Click:Connect(function()
                    local mp = UserInputService:GetMouseLocation()
                    Ripple(mp.X, mp.Y)
                    Tween(Btn, {BackgroundColor3 = Theme.Accent}, 0.08)
                    task.delay(0.1, function() Tween(Btn, {BackgroundColor3 = Theme.SurfaceHover}, 0.15) end)
                    callback()
                end)
                return Btn
            end

            -- ── TOGGLE ──────────────────────────────────────────
