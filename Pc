            SortOrder = Enum.SortOrder.LayoutOrder,
            FillDirection = Enum.FillDirection.Horizontal,
            HorizontalAlignment = Enum.HorizontalAlignment.Center,
        })
        Pad(Grid, 4, 8, 4, 4)

        -- Helper: get or create column cells
        -- Each "section" is a card that auto-sizes (we override grid with a different approach below)

        local function Activate()
            if _openDropdown then _openDropdown.close() end
            for _, t in ipairs(Window._tabs) do
                Tween(t._btn, {BackgroundColor3 = Theme.TabInactive, BackgroundTransparency = 0.3}, 0.18)
                t._lbl.TextColor3 = Theme.TextSec
                Tween(t._line, {Size = UDim2.new(0, 0, 0, 2), Position = UDim2.new(0.5, 0, 1, -2)}, 0.18)
                if t._ico then t._ico.ImageColor3 = Theme.TextSec end
                t._page.Visible = false
            end
            Tween(TabBtn, {BackgroundColor3 = Theme.AccentDark, BackgroundTransparency = 0}, 0.18)
            TabLabel.TextColor3 = Theme.TextAccent
            Tween(ActiveLine, {Size = UDim2.new(1, -16, 0, 2), Position = UDim2.new(0, 8, 1, -2)}, 0.22, Enum.EasingStyle.Back)
            Page.Visible = true
            Page.Position = UDim2.new(0, 10, 0, 0)
            Tween(Page, {Position = UDim2.new(0, 0, 0, 0)}, 0.2)
            Window._active = tabData
        end

        TabBtn.MouseButton1Click:Connect(Activate)
        tabData._btn  = TabBtn
        tabData._lbl  = TabLabel
        tabData._line = ActiveLine
        tabData._page = Page
        tabData._grid = Grid
        tabData._ico  = hasIcon and TabBtn:FindFirstChildWhichIsA("ImageLabel") or nil
        table.insert(Window._tabs, tabData)

        if #Window._tabs == 1 then Activate() end

        -- ============================================================
        -- CREATE SECTION (card in the 2-col grid)
        -- ============================================================
        function tabData:CreateSection(sTitle, fullWidth)
            local Section = {}

            -- We use a VStack Frame that auto-sizes
            -- The UIGridLayout handles 2-col placement
            -- fullWidth=true ‚Üí span full width using a LayoutOrder trick (we place a filler)
            
            local SCard = Create("Frame", {
                Parent = Grid,
                Size = UDim2.new(1, 0, 0, 0),
                BackgroundColor3 = Theme.Card,
                AutomaticSize = Enum.AutomaticSize.Y,
                ZIndex = 3,
                LayoutOrder = #tabData._sections + 1,
            })
            Corner(SCard, 10)
            Stroke(SCard, Theme.Border, 1, 0.4)

            -- Subtle inner gradient
            local innerGrad = Create("Frame", {
                Parent = SCard, Size = UDim2.new(1,0,1,0),
                BackgroundTransparency = 0.92, BackgroundColor3 = Theme.AccentDark, ZIndex = 2,
            })
            Corner(innerGrad, 10)
            Create("UIGradient", {
                Parent = innerGrad, Rotation = 120,
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Theme.AccentDark),
                    ColorSequenceKeypoint.new(1, Theme.BG),
                }),
            })

            Create("UIListLayout", {
                Parent = SCard, Padding = UDim.new(0, 4),
                SortOrder = Enum.SortOrder.LayoutOrder,
            })
            Pad(SCard, 8, 8, 10, 10)

            -- Section title header
            if sTitle and sTitle ~= "" then
                local header = Create("Frame", {
                    Parent = SCard, Size = UDim2.new(1, 0, 0, 22),
                    BackgroundTransparency = 1, ZIndex = 4,
                })
                Create("TextLabel", {
                    Parent = header, Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1, Text = sTitle:upper(),
                    TextColor3 = Theme.TextAccent, Font = Enum.Font.GothamBold,
                    TextSize = 10, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
                })
                Create("Frame", {
                    Parent = SCard, Size = UDim2.new(1, 0, 0, 1),
                    BackgroundColor3 = Theme.Border, BorderSizePixel = 0, ZIndex = 4,
                })
            end

            local function Row(h)
                h = h or 32
                return Create("Frame", {
                    Parent = SCard, Size = UDim2.new(1, 0, 0, h),
                    BackgroundTransparency = 1, ZIndex = 4,
                })
            end

            -- ==========================
            -- BUTTON
            -- ==========================
            function Section:AddButton(label, cb)
                cb = cb or function() end
                local row = Row(30)
                local Btn = Create("TextButton", {
                    Parent = row, Size = UDim2.new(1, 0, 1, 0),
                    BackgroundColor3 = Theme.Panel,
                    Text = label, TextColor3 = Theme.TextPri,
                    Font = Enum.Font.GothamSemibold, TextSize = 12,
                    AutoButtonColor = false, ZIndex = 5,
                })
                Corner(Btn, 7)
                local bs = Stroke(Btn, Theme.Border, 1)

                Btn.MouseEnter:Connect(function()
                    Tween(Btn, {BackgroundColor3 = Theme.CardHover}, 0.12)
                    Tween(bs, {Color = Theme.Accent}, 0.12)
                end)
                Btn.MouseLeave:Connect(function()
                    Tween(Btn, {BackgroundColor3 = Theme.Panel}, 0.12)
                    Tween(bs, {Color = Theme.Border}, 0.12)
                end)
                Btn.MouseButton1Click:Connect(function()
                    Tween(Btn, {BackgroundColor3 = Theme.AccentDark}, 0.08)
                    task.delay(0.12, function() Tween(Btn, {BackgroundColor3 = Theme.Panel}, 0.15) end)
                    -- Ripple
                    local mp = UserInputService:GetMouseLocation()
                    local r = Create("Frame", {
                        Parent = Btn, ZIndex = 6,
                        Size = UDim2.new(0,0,0,0),
                        Position = UDim2.new(0, mp.X - Btn.AbsolutePosition.X, 0, mp.Y - Btn.AbsolutePosition.Y),
                        BackgroundColor3 = Theme.Accent, BackgroundTransparency = 0.6,
                    })
                    Corner(r, 999)
                    Tween(r, {
                        Size = UDim2.new(0,120,0,120),
                        Position = UDim2.new(0, mp.X - Btn.AbsolutePosition.X - 60, 0, mp.Y - Btn.AbsolutePosition.Y - 60),
                        BackgroundTransparency = 1
                    }, 0.45)
                    task.delay(0.45, function() r:Destroy() end)
                    cb()
                end)
                return Btn
            end

            -- ==========================
            -- TOGGLE
            -- ==========================
            function Section:AddToggle(label, default, cb, cfgKey)
                cb = cb or function() end
                local state = default == true
                local row = Row(30)

                Create("TextLabel", {
                    Parent = row, Size = UDim2.new(1, -54, 1, 0),
                    BackgroundTransparency = 1, Text = label,
                    TextColor3 = Theme.TextPri, Font = Enum.Font.Gotham, TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 5,
                })

                local Track = Create("Frame", {
                    Parent = row, Position = UDim2.new(1, -48, 0.5, -10),
                    Size = UDim2.new(0, 42, 0, 20),
                    BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff, ZIndex = 5,
                })
                Corner(Track, 999)
                Stroke(Track, Theme.Border, 1)

                local Knob = Create("Frame", {
                    Parent = Track,
                    Size = UDim2.new(0, 14, 0, 14),
                    Position = state and UDim2.new(0, 24, 0.5, -7) or UDim2.new(0, 3, 0.5, -7),
                    BackgroundColor3 = Color3.fromRGB(255,255,255), ZIndex = 6,
                })
                Corner(Knob, 999)

                local TBtn = Create("TextButton", {
                    Parent = row, Size = UDim2.new(1,0,1,0),
                    BackgroundTransparency = 1, Text = "", ZIndex = 7,
                })

                local function SetState(val)
                    state = val
                    Tween(Track, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.18)
                    Tween(Knob, {Position = state and UDim2.new(0,24,0.5,-7) or UDim2.new(0,3,0.5,-7)}, 0.18, Enum.EasingStyle.Back)
                    cb(state)
                end

                TBtn.MouseButton1Click:Connect(function() SetState(not state) end)
                local obj = {Value = state, Set = SetState, Get = function() return state end}
                if cfgKey then table.insert(_elements, {key=cfgKey, get=function() return state end, set=SetState}) end
                return obj
            end

            -- ==========================
            -- SLIDER
            -- ==========================
            function Section:AddSlider(label, min, max, default, cb, decimals, cfgKey)
                min = min or 0; max = max or 100; decimals = decimals or 0
                default = RoundTo(math.clamp(default or min, min, max), decimals)
                cb = cb or function() end
                local value = default
                local row = Row(48)

                local LR = Create("Frame", {Parent=row, Size=UDim2.new(1,0,0,18), BackgroundTransparency=1, ZIndex=5})
                Create("TextLabel", {
                    Parent=LR, Size=UDim2.new(0.6,0,1,0),
                    BackgroundTransparency=1, Text=label,
                    TextColor3=Theme.TextPri, Font=Enum.Font.Gotham, TextSize=12,
                    TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5,
                })
                local VL = Create("TextLabel", {
                    Parent=LR, Position=UDim2.new(0.6,0,0,0),
                    Size=UDim2.new(0.4,0,1,0), BackgroundTransparency=1,
                    Text=tostring(default), TextColor3=Theme.TextAccent,
                    Font=Enum.Font.GothamBold, TextSize=12,
                    TextXAlignment=Enum.TextXAlignment.Right, ZIndex=5,
                })
                local Track = Create("Frame", {
                    Parent=row, Position=UDim2.new(0,0,0,26),
                    Size=UDim2.new(1,0,0,6),
                    BackgroundColor3=Theme.ToggleOff, ZIndex=5,
                })
                Corner(Track, 999)
                Stroke(Track, Theme.Border, 1)
                local Fill = Create("Frame", {
                    Parent=Track, Size=UDim2.new((default-min)/(max-min),0,1,0),
                    BackgroundColor3=Theme.SliderFill, ZIndex=6,
                })
                Corner(Fill, 999)
                Create("UIGradient", {Parent=Fill,
                    Color=ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Theme.AccentDark),
                        ColorSequenceKeypoint.new(1, Theme.AccentGlow),
                    })
                })
                local Thumb = Create("Frame", {
                    Parent=Track,
                    Size=UDim2.new(0,12,0,12),
                    Position=UDim2.new((default-min)/(max-min),-6,0.5,-6),
                    BackgroundColor3=Color3.fromRGB(255,255,255), ZIndex=7,
                })
                Corner(Thumb, 999)
                Stroke(Thumb, Theme.Accent, 1.5)
                local SBtn = Create("TextButton", {
                    Parent=Track, Size=UDim2.new(1,0,0,22),
                    Position=UDim2.new(0,0,0.5,-11),
                    BackgroundTransparency=1, Text="", ZIndex=8,
                })

                local sliding = false
                local function Upd(x)
                    local rel = math.clamp((x - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    value = RoundTo(min + rel*(max-min), decimals)
                    VL.Text = decimals>0 and string.format("%."..decimals.."f", value) or tostring(value)
                    local fr = (value-min)/(max-min)
                    Tween(Fill,  {Size=UDim2.new(fr,0,1,0)}, 0.04)
                    Tween(Thumb, {Position=UDim2.new(fr,-6,0.5,-6)}, 0.04)
                    cb(value)
                end
                SBtn.MouseButton1Down:Connect(function() sliding=true; Upd(UserInputService:GetMouseLocation().X) end)
                UserInputService.InputChanged:Connect(function(i)
                    if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                        Upd(i.Position.X)
                    end
                end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        sliding=false
                    end
                end)
                local function SetSlider(v)
                    v = RoundTo(math.clamp(v,min,max), decimals)
                    Upd(Track.AbsolutePosition.X + ((v-min)/(max-min))*Track.AbsoluteSize.X)
                end
                local obj = {Value=value, Set=SetSlider, Get=function() return value end}
                if cfgKey then table.insert(_elements, {key=cfgKey, get=function() return value end, set=SetSlider}) end
                return obj
            end

