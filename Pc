                })
                AddCorner(DDList, 8)
                AddStroke(DDList, Theme.Accent, 1.2)
                Create("UIListLayout", {Parent = DDList, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,2)})
                AddPadding(DDList, 4, 4, 4, 4)

                local function CloseDD()
                    if not open then return end
                    open = false
                    if renderConn then renderConn:Disconnect(); renderConn = nil end
                    if _openDropdown and _openDropdown.list == DDList then _openDropdown = nil end
                    Overlay.Visible = false
                    DDList.Visible  = false
                    DDBtn.Text = BtnText()
                end
                Overlay.MouseButton1Click:Connect(CloseDD)

                local function BuildOptions(optList)
                    for _, c in ipairs(DDList:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _, opt in ipairs(optList) do
                        local OptBtn = Create("TextButton", {
                            Parent = DDList, Size = UDim2.new(1,0,0,26),
                            BackgroundColor3 = Theme.SurfaceAlt,
                            Text = opt,
                            TextColor3 = (opt == selected) and Theme.Accent or Theme.TextPrimary,
                            Font = Enum.Font.Gotham, TextSize = 11,
                            AutoButtonColor = false, ZIndex = 51,
                        })
                        AddCorner(OptBtn, 6)
                        OptBtn.MouseEnter:Connect(function() Tween(OptBtn, {BackgroundColor3 = Theme.SurfaceHover}, 0.1) end)
                        OptBtn.MouseLeave:Connect(function() Tween(OptBtn, {BackgroundColor3 = Theme.SurfaceAlt}, 0.1) end)
                        OptBtn.MouseButton1Click:Connect(function()
                            selected = opt
                            DDBtn.Text = BtnText()
                            DDBtn.TextColor3 = Theme.TextPrimary
                            for _, c2 in ipairs(DDList:GetChildren()) do
                                if c2:IsA("TextButton") then
                                    c2.TextColor3 = (c2.Text == selected) and Theme.Accent or Theme.TextPrimary
                                end
                            end
                            CloseDD(); callback(selected)
                        end)
                    end
                end
                BuildOptions(options)

                local function OpenDD()
                    if _openDropdown then _openDropdown.close() end
                    open = true
                    _openDropdown = {close = CloseDD, list = DDList}
                    local btnSz = DDBtn.AbsoluteSize
                    local targetH = math.min(#options * 30 + 10, 180)
                    DDList.Size = UDim2.new(0, btnSz.X, 0, 0)
