                AddPadding(DDList, 4, 4, 4, 4)

                local function CloseDD()
                    if not open then return end
                    open = false
                    if renderConn then
                        renderConn:Disconnect()
                        renderConn = nil
                    end
                    if _openDropdown and _openDropdown.list == DDList then
                        _openDropdown = nil
                    end
                    Overlay.Visible = false
                    DDList.Visible  = false
                    DDList.Size     = UDim2.new(0, DDList.Size.X.Offset, 0, 0)
                    DDBtn.Text = BtnLabel()
                end

                Overlay.MouseButton1Click:Connect(CloseDD)

                local function BuildOptions(optList)
                    for _, c in ipairs(DDList:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _, opt in ipairs(optList) do
                        local OptBtn = Create("TextButton", {
                            Parent = DDList, Size = UDim2.new(1, 0, 0, 26),
                            BackgroundColor3 = Theme.Surface,
                            Text = opt,
                            TextColor3 = (opt == selected) and Theme.Accent or Theme.TextPrimary,
                            Font = Enum.Font.Gotham, TextSize = 12,
                            AutoButtonColor = false, ZIndex = 51,
                        })
                        AddCorner(OptBtn, 6)
                        OptBtn.MouseEnter:Connect(function() Tween(OptBtn, {BackgroundColor3 = Theme.SurfaceAlt}, 0.1) end)
                        OptBtn.MouseLeave:Connect(function() Tween(OptBtn, {BackgroundColor3 = Theme.Surface}, 0.1) end)
                        OptBtn.MouseButton1Click:Connect(function()
                            selected = opt
                            DDBtn.Text = BtnLabel()
                            DDBtn.TextColor3 = Theme.TextPrimary
                            for _, c2 in ipairs(DDList:GetChildren()) do
                                if c2:IsA("TextButton") then
                                    c2.TextColor3 = (c2.Text == selected) and Theme.Accent or Theme.TextPrimary
                                end
                            end
                            CloseDD()
                            callback(selected)
                        end)
                    end
                end
                BuildOptions(options)

                local function OpenDD()
                    if _openDropdown then _openDropdown.close() end
                    open = true
                    _openDropdown = {close = CloseDD, list = DDList}

                    local btnSize = DDBtn.AbsoluteSize
                    local btnW    = btnSize.X
                    local targetH = math.min(#options * 30 + 10, 180)

                    DDList.Size     = UDim2.new(0, btnW, 0, 0)
                    DDList.Visible  = true
                    Overlay.Visible = true

                    renderConn = RunService.RenderStepped:Connect(function()
                        local absPos = DDBtn.AbsolutePosition
                        local hubBottom = Main.AbsolutePosition.Y + Main.AbsoluteSize.Y
                        local spaceBelow = hubBottom - (absPos.Y + btnSize.Y)
                        local isUp = spaceBelow < targetH
                        local currentH = DDList.AbsoluteSize.Y
                        local targetY = isUp and (absPos.Y - currentH - 4) or (absPos.Y + btnSize.Y + 4)
                        DDList.Position = UDim2.new(0, absPos.X, 0, targetY)
                    end)

                    Tween(DDList, {Size = UDim2.new(0, btnW, 0, targetH)}, 0.2, Enum.EasingStyle.Back)
                    DDBtn.Text = (selected or "Select...") .. " ^"
                end

                DDBtn.MouseButton1Click:Connect(function()
                    if open then CloseDD() else OpenDD() end
                end)
                DDBtn.MouseEnter:Connect(function() Tween(ddStroke, {Color = Theme.Accent}, 0.15) end)
                DDBtn.MouseLeave:Connect(function() Tween(ddStroke, {Color = Theme.Border}, 0.15) end)

                local ddObj = {
                    Value = selected,
                    Get   = function() return selected end,
                    Set   = function(v)
                        selected = v
                        DDBtn.Text = BtnLabel()
                        DDBtn.TextColor3 = selected and Theme.TextPrimary or Theme.TextDim
                        callback(v)
                    end,
                    SetOptions = function(newOptions, keepSelected)
                        options = newOptions or {}
                        local valid = false
                        for _, v in ipairs(options) do
                            if v == keepSelected then valid = true; break end
                        end
                        selected = valid and keepSelected or nil
                        DDBtn.Text = BtnLabel()
                        DDBtn.TextColor3 = selected and Theme.TextPrimary or Theme.TextDim
                        BuildOptions(options)
                    end,
                }
                if configKey then
                    table.insert(Window._elements, {key = configKey,
                        get = function() return selected end,
                        set = ddObj.Set})
                end
                return ddObj
            end

