    function Window:Notify(title, message, ntype, duration)
        ntype    = ntype    or "info"
        duration = duration or 3

        local colors = {info=Theme.Accent, success=Theme.Success, warning=Theme.Warning, error=Theme.Danger}
        local icons  = {info="rbxassetid://7543870919", success="rbxassetid://7543871645", warning="rbxassetid://7543871002", error="rbxassetid://7543870869"}
        local col  = colors[ntype] or Theme.Accent
        local icon = icons[ntype]  or icons.info

        local NHolder = ScreenGui:FindFirstChild("ACTED_NotifHolder")
        if not NHolder then
            NHolder = Create("Frame", {
                Name = "ACTED_NotifHolder", Parent = ScreenGui,
                Position = UDim2.new(1, -320, 1, -30),
                Size = UDim2.new(0, 300, 0, 0),
                BackgroundTransparency = 1, ZIndex = 200,
            })
            Create("UIListLayout", {
                Parent = NHolder,
                VerticalAlignment = Enum.VerticalAlignment.Bottom,
                HorizontalAlignment = Enum.HorizontalAlignment.Right,
                SortOrder = Enum.SortOrder.LayoutOrder,
