            Create("UIAspectRatioConstraint", {Parent = TabIcon, AspectRatio = 1, DominantAxis = Enum.DominantAxis.Height})
            AssetLoader.Apply(TabIcon, iconUrl)
            -- text-ul tab-ului se mutńÉ mai la dreapta dacńÉ iconi»õa e mai mare
            TabBtn.Text = string.rep(" ", math.floor(iconSize / 3)) .. name
        end

        local Page = Create("ScrollingFrame", {
