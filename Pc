    local function Serialize()
        local d = {}
        for _, el in ipairs(_elements) do d[el.key] = el.get() end
        local ok, j = pcall(function() return HttpService:JSONEncode(d) end)
        return ok and j or nil
    end

    local function Apply(json)
        local ok, d = pcall(function() return HttpService:JSONDecode(json) end)
        if not ok or type(d) ~= "table" then return false end
        for _, el in ipairs(_elements) do
            if d[el.key] ~= nil then pcall(function() el.set(d[el.key]) end) end
        end
        return true
    end

    function Window:SaveConfig(name)
        EnsureFolders(); name = name or "default"
        local j = Serialize()
        if not j then self:Notify("Config", "Serialization failed.", "error", 3); return end
        local ok = false
        pcall(function() writefile(CfgFile(name), j); AddToList(name); ok = true end)
        if ok then self:Notify("Config", "Saved: " .. name .. ".cfg", "success", 3)
        else self:Notify("Config", "Saved to console (no writefile).", "warning", 3); print(j) end
    end

    function Window:LoadConfig(name, json)
        EnsureFolders(); name = name or "default"
        local j = json
        if not j then
            local ok, c = pcall(readfile, CfgFile(name))
            if ok and c then j = c
            else self:Notify("Config", "Not found: " .. name .. ".cfg", "error", 3); return end
        end
        if Apply(j) then self:Notify("Config", "Loaded: " .. name .. ".cfg", "success", 3)
        else self:Notify("Config", "Load failed.", "error", 3) end
    end

    function Window:DeleteConfig(name)
        EnsureFolders(); name = name or "default"
        pcall(function() delfile(CfgFile(name)) end)
        RemoveFromList(name)
        self:Notify("Config", "Deleted: " .. name .. ".cfg", "info", 3)
    end

    function Window:AddConfigManager(section)
        section:AddLabel("‚öô SETTINGS MANAGER", Theme.Accent)
        section:AddDivider()

        local nameBox = section:AddTextbox("Setting name", "Enter name...", "", function() end)
        local settingList = ReadList()
        local selectedSetting = nil
        local settingDropdown = nil
        local autoLoadToggle = nil
        local alData = ReadAutoLoad()

        if alData.enabled and alData.setting then
            for _, v in ipairs(settingList) do
                if v == alData.setting then selectedSetting = v; break end
            end
        end

        local function RefreshDD()
            settingList = ReadList()
            if settingDropdown then
                local found = false
                for _, v in ipairs(settingList) do
                    if v == selectedSetting then found = true; break end
                end
                if not found then selectedSetting = nil end
                settingDropdown.SetOptions(settingList, selectedSetting)
            end
        end

        settingDropdown = section:AddDropdown("Select setting", settingList, selectedSetting, function(v)
            selectedSetting = v
            if autoLoadToggle and autoLoadToggle.Get() then
                WriteAutoLoad(true, selectedSetting)
            end
        end)

        autoLoadToggle = section:AddToggle("Auto Load Setting", alData.enabled, function(state)
            if state then
                if not selectedSetting or selectedSetting == "" then
                    self:Notify("Auto Load", "Select a setting first.", "warning", 3)
                    autoLoadToggle.Set(false); WriteAutoLoad(false, nil); return
                end
                WriteAutoLoad(true, selectedSetting)
                self:Notify("Auto Load", "Enabled: " .. tostring(selectedSetting), "success", 3)
            else
                WriteAutoLoad(false, nil)
                self:Notify("Auto Load", "Disabled.", "info", 3)
            end
        end)

        section:AddButton("ūüíĺ  Save setting", function()
            local name = nameBox.Get()
            if not name or name == "" then name = selectedSetting end
            if not name or name == "" then self:Notify("Config", "Type a name first.", "warning", 3); return end
            self:SaveConfig(name); RefreshDD()
        end)

        section:AddButton("ūüďā  Load selected", function()
            if not selectedSetting or selectedSetting == "" then
                self:Notify("Config", "Select a setting first.", "warning", 3); return
            end
            self:LoadConfig(selectedSetting)
        end)

        section:AddButton("ūüóĎ  Delete selected", function()
            if not selectedSetting or selectedSetting == "" then
                self:Notify("Config", "Select a setting first.", "warning", 3); return
            end
            self:DeleteConfig(selectedSetting)
            local al = ReadAutoLoad()
            if al.enabled and al.setting == selectedSetting then
                WriteAutoLoad(false, nil)
                if autoLoadToggle then autoLoadToggle.Set(false) end
            end
            selectedSetting = nil; RefreshDD()
        end)

        section:AddButton("ūüĒĄ  Refresh list", function()
            RefreshDD(); self:Notify("Config", "Refreshed.", "info", 2)
        end)

        section:AddDivider()

        if alData.enabled and alData.setting then
            local target = alData.setting
            local exists = false
            for _, v in ipairs(ReadList()) do if v == target then exists = true; break end end
            if exists then
                task.delay(0.9, function()
                    self:LoadConfig(target)
                    selectedSetting = target
                    settingDropdown.SetOptions(ReadList(), target)
                end)
            else
                WriteAutoLoad(false, nil)
                if autoLoadToggle then autoLoadToggle.Set(false) end
            end
        end
    end

