            Parent = NFrame, Size = UDim2.new(0, 3, 1, -16),
            Position = UDim2.new(0, 0, 0, 8),
            BackgroundColor3 = col, BorderSizePixel = 0, ZIndex = 201,
        })
        AddCorner(Stripe, 2)

        -- Icon
        local IconFrame = Create("Frame", {
            Parent = NFrame, Position = UDim2.new(0, 12, 0.5, -16),
