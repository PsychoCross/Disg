            ImageColor3 = col, ZIndex = 202,
        })

        -- Text
        Create("TextLabel", {
            Parent = NFrame, Position = UDim2.new(0, 52, 0, 10),
            Size = UDim2.new(1, -60, 0, 16),
            BackgroundTransparency = 1, Text = title,
            TextColor3 = Theme.TextPrimary, Font = Enum.Font.GothamBold, TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 201,
        })
        Create("TextLabel", {
            Parent = NFrame, Position = UDim2.new(0, 52, 0, 28),
            Size = UDim2.new(1, -60, 0, 30),
            BackgroundTransparency = 1, Text = message,
            TextColor3 = Theme.TextSecondary, Font = Enum.Font.Gotham, TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,
            TextWrapped = true, ZIndex = 201,
        })

        -- Progress bar
        local ProgBG = Create("Frame", {
            Parent = NFrame, Size = UDim2.new(1, -16, 0, 2),
            Position = UDim2.new(0, 8, 1, -6),
            BackgroundColor3 = Theme.SurfaceHover, BorderSizePixel = 0, ZIndex = 201,
        })
        AddCorner(ProgBG, 1)
        local ProgFill = Create("Frame", {
            Parent = ProgBG, Size = UDim2.new(1,0,1,0),
            BackgroundColor3 = col, BorderSizePixel = 0, ZIndex = 202,
        })
        AddCorner(ProgFill, 1)

        -- Slide in
        Tween(NWrap, {Size = UDim2.new(1, 0, 0, 70)}, 0.35, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
        task.delay(0.08, function()
            Tween(NFrame, {Position = UDim2.new(0, 0, 0, 0)}, 0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
        end)
        Tween(ProgFill, {Size = UDim2.new(0, 0, 1, 0)}, duration, Enum.EasingStyle.Linear)

        task.delay(duration, function()
            Tween(NFrame, {Position = UDim2.new(0, 310, 0, 0), BackgroundTransparency = 1}, 0.35, Enum.EasingStyle.Exponential, Enum.EasingDirection.In)
            task.delay(0.35, function()
                Tween(NWrap, {Size = UDim2.new(1, 0, 0, 0)}, 0.25, Enum.EasingStyle.Quart)
                task.delay(0.26, function() NWrap:Destroy() end)
            end)
        end)
    end

    task.delay(0.5, function()
        Window:Notify("ACTED", "Hub loaded ‚ÄĒ " .. Theme.Name .. " theme active.", "success", 4)
    end)

    return Window
end

return ACTED
