                    local col = Color3.fromHSV(hue, sat, val_cp)
                    Swatch.BackgroundColor3 = col; HueThumb.Position = UDim2.new(hue, -5, 0.5, -9); callback(col)
                end
                local hSliding = false
                local HueDrag = Create("TextButton", {Parent = HueTrack, Size = UDim2.new(1, 0, 0, 24),
                    Position = UDim2.new(0, 0, 0.5, -12), BackgroundTransparency = 1, Text = "", ZIndex = 53,
