                })
                local Swatch=Create("Frame", {
                    Parent=row, Position=UDim2.new(1,-32,0.15,0),
                    Size=UDim2.new(0,26,0.7,0),
                    BackgroundColor3=default, ZIndex=5,
                })
                Corner(Swatch,6); Stroke(Swatch,Theme.Border,1)

                local hue,sat,val_=Color3.toHSV(default)
                local cpOpen=false

                local CPF=Create("Frame", {
                    Parent=ScreenGui, Size=UDim2.new(0,160,0,0),
                    BackgroundColor3=Theme.Card, Visible=false, ZIndex=50, ClipsDescendants=true,
                })
                Corner(CPF,10); Stroke(CPF,Theme.Accent,1.2)

                local HT=Create("Frame", {
                    Parent=CPF, Position=UDim2.new(0,8,0,10),
                    Size=UDim2.new(1,-16,0,14),
                    BackgroundColor3=Color3.fromRGB(200,200,200), ZIndex=51,
                })
                Corner(HT,999)
                Create("UIGradient", {Parent=HT, Color=ColorSequence.new({
                    ColorSequenceKeypoint.new(0,   Color3.fromHSV(0,1,1)),
                    ColorSequenceKeypoint.new(1/6, Color3.fromHSV(1/6,1,1)),
                    ColorSequenceKeypoint.new(2/6, Color3.fromHSV(2/6,1,1)),
                    ColorSequenceKeypoint.new(3/6, Color3.fromHSV(3/6,1,1)),
                    ColorSequenceKeypoint.new(4/6, Color3.fromHSV(4/6,1,1)),
                    ColorSequenceKeypoint.new(5/6, Color3.fromHSV(5/6,1,1)),
                    ColorSequenceKeypoint.new(1,   Color3.fromHSV(1,1,1)),
                })})
                local HTh=Create("Frame",{Parent=HT,Size=UDim2.new(0,10,0,18),Position=UDim2.new(hue,-5,0.5,-9),BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=52})
                Corner(HTh,999)

                local function UpdCol()
                    local c=Color3.fromHSV(hue,sat,val_)
                    Swatch.BackgroundColor3=c; HTh.Position=UDim2.new(hue,-5,0.5,-9); cb(c)
                end

                local hs=false
                local HD=Create("TextButton",{Parent=HT,Size=UDim2.new(1,0,0,24),Position=UDim2.new(0,0,0.5,-12),BackgroundTransparency=1,Text="",ZIndex=53})
                HD.MouseButton1Down:Connect(function() hs=true end)
                UserInputService.InputChanged:Connect(function(i)
                    if hs and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                        hue=math.clamp((i.Position.X-HT.AbsolutePosition.X)/HT.AbsoluteSize.X,0,1); UpdCol()
                    end
                end)
                UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then hs=false end end)

                local SB=Create("TextButton",{Parent=row,Size=UDim2.new(0,30,1,0),Position=UDim2.new(1,-32,0,0),BackgroundTransparency=1,Text="",ZIndex=6})
                SB.MouseButton1Click:Connect(function()
                    cpOpen=not cpOpen
                    local ap=Swatch.AbsolutePosition
                    CPF.Position=UDim2.new(0,ap.X-120,0,ap.Y+26); CPF.Visible=true
                    Tween(CPF,{Size=UDim2.new(0,160,0,cpOpen and 52 or 0)},0.18,Enum.EasingStyle.Back)
                    if not cpOpen then task.delay(0.2,function() CPF.Visible=false end) end
                end)
                UpdCol()
                local function GetColor() return Color3.fromHSV(hue,sat,val_) end
                local obj={Get=GetColor}
                if cfgKey then table.insert(_elements,{key=cfgKey,get=function() local c=GetColor() return{r=c.R,g=c.G,b=c.B} end,set=function(v) if type(v)=="table" then local c=Color3.new(v.r,v.g,v.b) hue,sat,val_=Color3.toHSV(c) UpdCol() end end}) end
                return obj
            end

            table.insert(tabData._sections, Section)
            return Section
        end

        return tabData
    end

    -- ============================================================
    -- NOTIFICATIONS
    -- ============================================================
    function Window:Notify(title, message, ntype, duration)
        ntype=ntype or "info"; duration=duration or 3
        local cols={info=Theme.Info, success=Theme.Success, warning=Theme.Warning, error=Theme.Danger}
        local icons={info="‚ĄĻ", success="‚úď", warning="‚ö†", error="‚úē"}
        local col=cols[ntype] or Theme.Info
        local ico=icons[ntype] or "i"

        local NH=ScreenGui:FindFirstChild("ACTED_NH")
        if not NH then
            NH=Create("Frame", {
                Name="ACTED_NH", Parent=ScreenGui,
                Position=UDim2.new(1,-330,1,-30),
                Size=UDim2.new(0,310,0,0),
                BackgroundTransparency=1, ZIndex=200,
            })
            Create("UIListLayout",{
                Parent=NH, VerticalAlignment=Enum.VerticalAlignment.Bottom,
                HorizontalAlignment=Enum.HorizontalAlignment.Right,
                SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0,10),
            })
        end

        local NW=Create("Frame",{Parent=NH,Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,ClipsDescendants=true,ZIndex=200})
        local NF=Create("Frame",{
            Parent=NW, Size=UDim2.new(1,0,0,78),
            Position=UDim2.new(0,330,0,0),
            BackgroundColor3=Theme.Card, BackgroundTransparency=0.06, ZIndex=200,
        })
        Corner(NF,12); Stroke(NF,col,1.5,0.1)

        -- Left color bar
        Create("Frame",{
            Parent=NF, Size=UDim2.new(0,3,0.7,0),
            Position=UDim2.new(0,0,0.15,0),
            BackgroundColor3=col, BorderSizePixel=0, ZIndex=201,
        })
        Create("UICorner",{Parent=NF:FindFirstChildWhichIsA("Frame"),CornerRadius=UDim.new(0,2)})

        -- Icon circle
        local IR=Create("Frame",{Parent=NF,Position=UDim2.new(0,14,0.5,-16),Size=UDim2.new(0,32,0,32),BackgroundColor3=Theme.Panel,ZIndex=201})
        Corner(IR,16); Stroke(IR,col,1.5)
        Create("TextLabel",{Parent=IR,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=ico,TextColor3=col,Font=Enum.Font.GothamBold,TextSize=14,ZIndex=202})

        -- Text
        local TH=Create("Frame",{Parent=NF,Position=UDim2.new(0,54,0,0),Size=UDim2.new(1,-66,1,-10),BackgroundTransparency=1,ZIndex=201})
        Create("UIListLayout",{Parent=TH,SortOrder=Enum.SortOrder.LayoutOrder,VerticalAlignment=Enum.VerticalAlignment.Center,Padding=UDim.new(0,3)})
        Create("TextLabel",{Parent=TH,Size=UDim2.new(1,0,0,16),BackgroundTransparency=1,Text=title,TextColor3=Theme.TextPri,Font=Enum.Font.GothamBold,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=202})
        Create("TextLabel",{Parent=TH,Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,Text=message,TextColor3=Theme.TextSec,Font=Enum.Font.Gotham,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,AutomaticSize=Enum.AutomaticSize.Y,ZIndex=202})

        -- Progress bar
        local PB=Create("Frame",{Parent=NF,Size=UDim2.new(1,-28,0,2),Position=UDim2.new(0,14,1,-6),BackgroundColor3=Theme.Panel,BackgroundTransparency=0.4,BorderSizePixel=0,ZIndex=201})
        Corner(PB,2)
        local PF2=Create("Frame",{Parent=PB,Size=UDim2.new(1,0,1,0),BackgroundColor3=col,BorderSizePixel=0,ZIndex=202})
        Corner(PF2,2)

        -- Animate in
        Tween(NW,{Size=UDim2.new(1,0,0,78)},0.35,Enum.EasingStyle.Exponential,Enum.EasingDirection.Out)
        task.delay(0.05,function() Tween(NF,{Position=UDim2.new(0,0,0,0)},0.4,Enum.EasingStyle.Exponential,Enum.EasingDirection.Out) end)
        Tween(PF2,{Size=UDim2.new(0,0,1,0)},duration,Enum.EasingStyle.Linear)

        -- Animate out
        task.delay(duration,function()
            Tween(NF,{Position=UDim2.new(0,330,0,0),BackgroundTransparency=1},0.35,Enum.EasingStyle.Exponential,Enum.EasingDirection.In)
            task.delay(0.38,function()
                Tween(NW,{Size=UDim2.new(1,0,0,0)},0.25,Enum.EasingStyle.Exponential)
                task.delay(0.28,function() NW:Destroy() end)
            end)
        end)
    end

    -- Startup notification
    task.delay(0.7, function()
        Window:Notify("ACTED", "UI loaded successfully.", "success", 3)
    end)

    return Window
end

return ACTED
