-- ============================================================
-- Config / Folder System (same as v2.8)
-- ============================================================
local HUB_FOLDER      = "ACTED"
local CONFIG_FOLDER   = HUB_FOLDER .. "/configs"
local SETTINGS_FOLDER = HUB_FOLDER .. "/settings"
local SETTINGS_FILE   = SETTINGS_FOLDER .. "/ACTED_settings.json"
local AUTOLOAD_FILE   = SETTINGS_FOLDER .. "/ACTED_autoload.json"

local function EnsureFolders()
    pcall(function()
        if not isfolder(HUB_FOLDER)      then makefolder(HUB_FOLDER) end
        if not isfolder(CONFIG_FOLDER)   then makefolder(CONFIG_FOLDER) end
        if not isfolder(SETTINGS_FOLDER) then makefolder(SETTINGS_FOLDER) end
    end)
end
local function SettingFileName(n) return CONFIG_FOLDER .. "/" .. n .. ".cfg" end

local function ReadSettingList()
    EnsureFolders()
    local ok, raw = pcall(readfile, SETTINGS_FILE)
    if not ok or not raw then return {} end
    local ok2, d = pcall(function() return HttpService:JSONDecode(raw) end)
    return (ok2 and type(d) == "table") and d or {}
end
local function WriteSettingList(list)
    EnsureFolders()
    local ok, j = pcall(function() return HttpService:JSONEncode(list) end)
    if ok then pcall(writefile, SETTINGS_FILE, j) end
end
local function AddSettingToList(name)
    local l = ReadSettingList()
    for _, v in ipairs(l) do if v == name then return end end
    table.insert(l, name); WriteSettingList(l)
end
local function RemoveSettingFromList(name)
    local l, new = ReadSettingList(), {}
    for _, v in ipairs(l) do if v ~= name then table.insert(new, v) end end
    WriteSettingList(new)
end
local function ReadAutoLoad()
    EnsureFolders()
    local ok, raw = pcall(readfile, AUTOLOAD_FILE)
    if not ok or not raw then return {enabled = false, setting = nil} end
    local ok2, d = pcall(function() return HttpService:JSONDecode(raw) end)
    return (ok2 and type(d) == "table") and {enabled = d.enabled == true, setting = d.setting}
        or {enabled = false, setting = nil}
end
local function WriteAutoLoad(en, s)
    EnsureFolders()
    local ok, j = pcall(function() return HttpService:JSONEncode({enabled = en, setting = s}) end)
    if ok then pcall(writefile, AUTOLOAD_FILE, j) end
end

