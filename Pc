                    renderConn = RunService.RenderStepped:Connect(function()
                        local ap = DDBtn.AbsolutePosition
                        local hubBot = Main.AbsolutePosition.Y + Main.AbsoluteSize.Y
                        local spBelow = hubBot - (ap.Y + btnSz.Y)
                        local isUp = spBelow < targetH
                        local curH = DDList.AbsoluteSize.Y
                        local ty = isUp and (ap.Y - curH - 4) or (ap.Y + btnSz.Y + 4)
                        DDList.Position = UDim2.new(0, ap.X, 0, ty)
                    end)
                    Tween(DDList, {Size = UDim2.new(0, btnSz.X, 0, targetH)}, 0.2, Enum.EasingStyle.Back)
                    DDBtn.Text = (selected or "Select...") .. "  ‚Ėī"
                end

                DDBtn.MouseButton1Click:Connect(function()
                    if open then CloseDD() else OpenDD() end
                end)
                DDBtn.MouseEnter:Connect(function() Tween(ddStroke, {Color = Theme.Accent}, 0.12) end)
                DDBtn.MouseLeave:Connect(function() Tween(ddStroke, {Color = Theme.Border}, 0.12) end)

                local ddObj = {
                    Get = function() return selected end,
                    Set = function(v) selected = v; DDBtn.Text = BtnText(); DDBtn.TextColor3 = selected and Theme.TextPrimary or Theme.TextDim; callback(v) end,
                    SetOptions = function(newOpts, keepSel)
                        options = newOpts or {}
                        local valid = false
                        for _, v in ipairs(options) do if v == keepSel then valid = true; break end end
                        selected = valid and keepSel or nil
                        DDBtn.Text = BtnText(); DDBtn.TextColor3 = selected and Theme.TextPrimary or Theme.TextDim
                        BuildOptions(options)
                    end,
                }
                if configKey then
                    table.insert(Window._elements, {key = configKey, get = function() return selected end, set = ddObj.Set})
                end
                return ddObj
            end

