                    BackgroundColor3 = default, ZIndex = 6,
                })
                Corner(Swatch, 3)
                Stroke(Swatch, Theme.BorderDark, 1)

                local hue, sat, val_cp = Color3.toHSV(default)
                local CPFrame = Create("Frame", {
                    Parent = ScreenGui, Size = UDim2.new(0, 160, 0, 0),
                    BackgroundColor3 = Theme.BG2, Visible = false, ZIndex = 50,
                    ClipsDescendants = true,
                })
                Corner(CPFrame, 4)
                Stroke(CPFrame, Theme.Accent, 1)
                local HTrack = Create("Frame", {
                    Parent = CPFrame, Position = UDim2.new(0, 8, 0, 10),
                    Size = UDim2.new(1, -16, 0, 12),
                    BackgroundColor3 = Color3.new(1,1,1), ZIndex = 51,
                })
                Corner(HTrack, 2)
                Create("UIGradient", {Parent = HTrack, Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0,   Color3.fromHSV(0,   1, 1)),
                    ColorSequenceKeypoint.new(1/6, Color3.fromHSV(1/6, 1, 1)),
                    ColorSequenceKeypoint.new(2/6, Color3.fromHSV(2/6, 1, 1)),
                    ColorSequenceKeypoint.new(3/6, Color3.fromHSV(3/6, 1, 1)),
                    ColorSequenceKeypoint.new(4/6, Color3.fromHSV(4/6, 1, 1)),
                    ColorSequenceKeypoint.new(5/6, Color3.fromHSV(5/6, 1, 1)),
                    ColorSequenceKeypoint.new(1,   Color3.fromHSV(1,   1, 1)),
                })})
                local HThumb = Create("Frame", {
                    Parent = HTrack, Size = UDim2.new(0, 8, 0, 16),
                    Position = UDim2.new(hue, 0 - 4, 0.5, -8),
                    BackgroundColor3 = Color3.new(1,1,1), ZIndex = 52,
                })
                Corner(HThumb, 2)

                local function UpdColor()
                    local c = Color3.fromHSV(hue, sat, val_cp)
                    Swatch.BackgroundColor3 = c
                    HThumb.Position = UDim2.new(hue, 0 - 4, 0.5, -8)
                    callback(c)
                end

                local hSlide = false
                local HDrag = Create("TextButton", {
                    Parent = HTrack, Size = UDim2.new(1, 0, 0, 22),
                    Position = UDim2.new(0, 0, 0.5, -11), BackgroundTransparency = 1, Text = "", ZIndex = 53,
                })
                HDrag.MouseButton1Down:Connect(function() hSlide = true end)
                UserInputService.InputChanged:Connect(function(inp)
                    if hSlide and (inp.UserInputType == Enum.UserInputType.MouseMovement
                                or inp.UserInputType == Enum.UserInputType.Touch) then
                        hue = math.clamp((inp.Position.X - HTrack.AbsolutePosition.X) / HTrack.AbsoluteSize.X, 0, 1)
                        UpdColor()
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then hSlide = false end
                end)

                local cpOpen = false
                local SwBtn = Create("TextButton", {
                    Parent = row, Size = UDim2.new(0, 54, 1, 0),
                    Position = UDim2.new(1, -54, 0, 0),
                    BackgroundTransparency = 1, Text = "", ZIndex = 7,
                })
                SwBtn.MouseButton1Click:Connect(function()
                    cpOpen = not cpOpen
                    local ap = Swatch.AbsolutePosition
                    CPFrame.Position = UDim2.new(0, ap.X - 106, 0, ap.Y + 24)
                    CPFrame.Visible = true
                    Tween(CPFrame, {Size = UDim2.new(0, 160, 0, cpOpen and 50 or 0)}, 0.15)
                    if not cpOpen then task.delay(0.18, function() CPFrame.Visible = false end) end
                end)
                UpdColor()

                local function GetColor() return Color3.fromHSV(hue, sat, val_cp) end
                local obj = {Get = GetColor}
                if configKey then
                    table.insert(Window._elements, {key = configKey,
                        get = function() local c = GetColor(); return {r=c.R,g=c.G,b=c.B} end,
                        set = function(v)
                            if type(v) == "table" then
                                local c = Color3.new(v.r,v.g,v.b)
                                hue,sat,val_cp = Color3.toHSV(c); UpdColor()
                            end
                        end})
                end
                return obj
            end

            -- ==========================
            -- LABEL
            -- ==========================
            function Sec:AddLabel(text, color)
                local row = Row(18)
                Create("TextLabel", {
                    Parent = row, Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1, Text = text,
                    TextColor3 = color or Theme.TextMid,
                    Font = Enum.Font.Code, TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 6, TextWrapped = true,
                })
            end

            -- ==========================
            -- KEYBIND
            -- ==========================
            function Sec:AddKeybind(label, default, callback, configKey)
                callback = callback or function() end
                default  = default  or Enum.KeyCode.RightShift
                local key = default
                local listening = false
                local row = Row(30)
                Create("TextLabel", {
                    Parent = row, Size = UDim2.new(0.6, 0, 1, 0),
                    BackgroundTransparency = 1, Text = label,
                    TextColor3 = Theme.TextBright, Font = Enum.Font.Code, TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6,
                })
                local KBtn = Create("TextButton", {
                    Parent = row, Position = UDim2.new(0.62, 0, 0.1, 0),
                    Size = UDim2.new(0.38, 0, 0.8, 0),
                    BackgroundColor3 = Theme.BG2,
                    Text = "[" .. key.Name .. "]",
                    TextColor3 = Theme.Accent, Font = Enum.Font.Code, TextSize = 11,
                    AutoButtonColor = false, ZIndex = 6,
                })
                Corner(KBtn, 3)
                Stroke(KBtn, Theme.BorderDark, 1)
                KBtn.MouseButton1Click:Connect(function()
                    listening = true
                    KBtn.Text = "[???]"
                    KBtn.TextColor3 = Theme.Warning
                end)
                UserInputService.InputBegan:Connect(function(inp)
                    if listening and inp.UserInputType == Enum.UserInputType.Keyboard then
                        key = inp.KeyCode
                        KBtn.Text = "[" .. key.Name .. "]"
                        KBtn.TextColor3 = Theme.Accent
                        listening = false
                    end
                    if not listening and inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == key then
                        callback(key)
                    end
                end)
                local obj = {Get = function() return key end}
                if configKey then
                    table.insert(Window._elements, {key = configKey,
                        get = function() return key.Name end,
                        set = function(v)
                            local ok, kc = pcall(function() return Enum.KeyCode[v] end)
                            if ok and kc then key = kc; KBtn.Text = "[" .. v .. "]" end
                        end})
                end
                return obj
            end

            -- ==========================
            -- DIVIDER
            -- ==========================
            function Sec:AddDivider()
                local row = Row(8)
                Create("Frame", {
                    Parent = row, Size = UDim2.new(1, 0, 0, 1),
                    Position = UDim2.new(0, 0, 0.5, 0),
                    BackgroundColor3 = Theme.BorderDark, BorderSizePixel = 0, ZIndex = 6,
                })
            end

            table.insert(tabData._sections, Sec)
            return Sec
        end

        return tabData
    end

    -- ============================================================
    -- NOTIFICATIONS  (terminal-style, right side)
    -- ============================================================
    function Window:Notify(title, message, ntype, duration)
        ntype    = ntype    or "info"
        duration = duration or 3
        local colors = {info = Theme.Info, success = Theme.Success, warning = Theme.Warning, error = Theme.Danger}
        local prefixes = {info = "[~]", success = "[+]", warning = "[!]", error = "[-]"}
        local col    = colors[ntype]   or Theme.Info
        local prefix = prefixes[ntype] or "[~]"

        local NHolder = ScreenGui:FindFirstChild("ACTED_NH")
        if not NHolder then
            NHolder = Create("Frame", {
                Name = "ACTED_NH", Parent = ScreenGui,
                Position = UDim2.new(1, -320, 1, -30),
                Size = UDim2.new(0, 300, 0, 0),
                BackgroundTransparency = 1, ZIndex = 200,
            })
            Create("UIListLayout", {
                Parent = NHolder,
                VerticalAlignment = Enum.VerticalAlignment.Bottom,
                HorizontalAlignment = Enum.HorizontalAlignment.Right,
                SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6),
            })
        end

        local NWrap = Create("Frame", {
            Parent = NHolder, Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1, ClipsDescendants = true, ZIndex = 200,
        })

        local NF = Create("Frame", {
            Parent = NWrap, Size = UDim2.new(1, 0, 0, 60),
            Position = UDim2.new(0, 310, 0, 0),
            BackgroundColor3 = Theme.BG1,
            BackgroundTransparency = 0.05, ZIndex = 200,
        })
        Corner(NF, 3)
        Stroke(NF, col, 1, 0.2)

        -- Left accent bar
        Create("Frame", {
            Parent = NF, Size = UDim2.new(0, 2, 1, 0),
            BackgroundColor3 = col, BorderSizePixel = 0, ZIndex = 201,
        })

        -- Title + message
        Create("TextLabel", {
            Parent = NF, Position = UDim2.new(0, 12, 0, 8),
            Size = UDim2.new(1, -16, 0, 18),
            BackgroundTransparency = 1,
            Text = prefix .. " " .. title:upper(),
            TextColor3 = col, Font = Enum.Font.Code, TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 201,
        })
        Create("TextLabel", {
            Parent = NF, Position = UDim2.new(0, 12, 0, 26),
            Size = UDim2.new(1, -16, 0, 26),
            BackgroundTransparency = 1,
            Text = message, TextColor3 = Theme.TextMid,
            Font = Enum.Font.Code, TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true, ZIndex = 201,
        })

        -- Progress bar
        local PBG = Create("Frame", {
            Parent = NF, Size = UDim2.new(1, -14, 0, 2),
            Position = UDim2.new(0, 12, 1, -4),
            BackgroundColor3 = Theme.BG3, BorderSizePixel = 0, ZIndex = 201,
        })
        Corner(PBG, 1)
        local PFill = Create("Frame", {
            Parent = PBG, Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = col, BorderSizePixel = 0, ZIndex = 202,
        })
        Corner(PFill, 1)

        -- Animate in
        Tween(NWrap, {Size = UDim2.new(1, 0, 0, 60)}, 0.25, Enum.EasingStyle.Quart)
        task.delay(0.05, function()
            Tween(NF, {Position = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Quart)
        end)
        Tween(PFill, {Size = UDim2.new(0, 0, 1, 0)}, duration, Enum.EasingStyle.Linear)

        task.delay(duration, function()
            Tween(NF, {Position = UDim2.new(0, 310, 0, 0), BackgroundTransparency = 1}, 0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
            task.delay(0.28, function()
                Tween(NWrap, {Size = UDim2.new(1, 0, 0, 0)}, 0.2)
                task.delay(0.22, function() NWrap:Destroy() end)
            end)
        end)
    end

    task.delay(0.5, function()
        Window:Notify("SYSTEM", "Core modules loaded OK", "success", 3)
    end)

    return Window
end

return ACTED
