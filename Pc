            -- ==========================
            -- DROPDOWN
            -- ==========================
            function Sec:AddDropdown(label, options, default, callback, configKey)
                callback = callback or function() end
                options = options or {}
                local selected = default
                local open = false
                local renderConn = nil
                local row = Row(30)

                Create("TextLabel", {
                    Parent = row, Size = UDim2.new(0.45, 0, 1, 0),
                    BackgroundTransparency = 1, Text = label,
                    TextColor3 = Theme.TextBright, Font = Enum.Font.Code, TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6,
                })
                local function BtnTxt() return (selected or "...") .. " [v]" end
                local DDBtn = Create("TextButton", {
                    Parent = row, Position = UDim2.new(0.47, 0, 0.1, 0),
                    Size = UDim2.new(0.53, 0, 0.8, 0),
                    BackgroundColor3 = Theme.BG2,
                    Text = BtnTxt(),
                    TextColor3 = selected and Theme.Accent or Theme.TextDim,
                    Font = Enum.Font.Code, TextSize = 11,
                    AutoButtonColor = false, ZIndex = 6,
                })
                Corner(DDBtn, 3)
                local ddSt = Stroke(DDBtn, Theme.BorderDark, 1)

                local Overlay = Create("TextButton", {
                    Parent = ScreenGui, Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1, Text = "", ZIndex = 49, Visible = false,
                    AutoButtonColor = false,
                })
                local DDList = Create("ScrollingFrame", {
                    Parent = ScreenGui, Size = UDim2.new(0, 0, 0, 0),
                    BackgroundColor3 = Theme.BG2,
                    Visible = false, ZIndex = 50, ClipsDescendants = true,
                    ScrollBarThickness = 2, ScrollBarImageColor3 = Theme.Accent,
                    CanvasSize = UDim2.new(0, 0, 0, 0),
                    AutomaticCanvasSize = Enum.AutomaticSize.Y,
                    BorderSizePixel = 0,
                })
                Corner(DDList, 3)
                Stroke(DDList, Theme.Accent, 1, 0.3)
                Create("UIListLayout", {Parent = DDList, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 1)})
                Pad(DDList, 3, 3, 3, 3)

                local function CloseDD()
                    if not open then return end
                    open = false
                    if renderConn then renderConn:Disconnect(); renderConn = nil end
                    if _openDropdown and _openDropdown.list == DDList then _openDropdown = nil end
                    Overlay.Visible = false; DDList.Visible = false
                    DDList.Size = UDim2.new(0, DDList.Size.X.Offset, 0, 0)
                    DDBtn.Text = BtnTxt()
                end
                Overlay.MouseButton1Click:Connect(CloseDD)

                local function BuildOpts(list)
                    for _, c in ipairs(DDList:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _, opt in ipairs(list) do
                        local ob = Create("TextButton", {
                            Parent = DDList, Size = UDim2.new(1, 0, 0, 22),
                            BackgroundColor3 = (opt == selected) and Theme.AccentBG or Theme.BG2,
                            Text = (opt == selected and "> " or "  ") .. opt,
                            TextColor3 = (opt == selected) and Theme.Accent or Theme.TextBright,
                            Font = Enum.Font.Code, TextSize = 11,
                            AutoButtonColor = false, ZIndex = 51,
                            TextXAlignment = Enum.TextXAlignment.Left,
                        })
                        Corner(ob, 2)
                        Pad(ob, 0, 0, 6, 0)
                        ob.MouseEnter:Connect(function() if opt ~= selected then Tween(ob, {BackgroundColor3 = Theme.BG3}, 0.08) end end)
                        ob.MouseLeave:Connect(function() if opt ~= selected then Tween(ob, {BackgroundColor3 = Theme.BG2}, 0.08) end end)
                        ob.MouseButton1Click:Connect(function()
                            selected = opt
                            DDBtn.Text = BtnTxt()
                            DDBtn.TextColor3 = Theme.Accent
                            CloseDD(); callback(selected)
                        end)
                    end
                end
                BuildOpts(options)

                local function OpenDD()
                    if _openDropdown then _openDropdown.close() end
                    open = true
                    _openDropdown = {close = CloseDD, list = DDList}
                    local bW = DDBtn.AbsoluteSize.X
                    local tH = math.min(#options * 25 + 8, 160)
                    DDList.Size = UDim2.new(0, bW, 0, 0)
                    DDList.Visible = true; Overlay.Visible = true
                    renderConn = RunService.RenderStepped:Connect(function()
                        local ap = DDBtn.AbsolutePosition
                        local bottom = Main.AbsolutePosition.Y + Main.AbsoluteSize.Y
                        local space = bottom - (ap.Y + DDBtn.AbsoluteSize.Y)
                        local curH = DDList.AbsoluteSize.Y
                        local ty = (space < tH) and (ap.Y - curH - 2) or (ap.Y + DDBtn.AbsoluteSize.Y + 2)
                        DDList.Position = UDim2.new(0, ap.X, 0, ty)
                    end)
                    Tween(DDList, {Size = UDim2.new(0, bW, 0, tH)}, 0.15, Enum.EasingStyle.Quart)
                    DDBtn.Text = (selected or "...") .. " [^]"
                end

                DDBtn.MouseButton1Click:Connect(function() if open then CloseDD() else OpenDD() end end)
                DDBtn.MouseEnter:Connect(function() Tween(ddSt, {Color = Theme.AccentDim}, 0.1) end)
                DDBtn.MouseLeave:Connect(function() Tween(ddSt, {Color = Theme.BorderDark}, 0.1) end)

                local obj = {
                    Get = function() return selected end,
                    Set = function(v) selected = v; DDBtn.Text = BtnTxt(); DDBtn.TextColor3 = selected and Theme.Accent or Theme.TextDim; callback(v) end,
                    SetOptions = function(newOpts, keep)
                        options = newOpts or {}
                        local valid = false
                        for _, v in ipairs(options) do if v == keep then valid = true; break end end
                        selected = valid and keep or nil
                        DDBtn.Text = BtnTxt(); DDBtn.TextColor3 = selected and Theme.Accent or Theme.TextDim
                        BuildOpts(options)
                    end,
                }
                if configKey then
                    table.insert(Window._elements, {key = configKey, get = function() return selected end, set = obj.Set})
                end
                return obj
            end

            -- ==========================
