        if type(icon) == "string" then
            if icon:match("^url:") then
                local key = icon:gsub("^url:", "")
                iconUrl = ASSET_URLS.Tabs[key]
                iconIsImage = iconUrl ~= nil
            elseif icon:match("^https?://") then
                iconUrl = icon
                iconIsImage = true
            end
        end

        local TabBtn = Create("TextButton", {
            Parent = TabBar,
            Size   = UDim2.new(1, 0, 0, 36),
            BackgroundColor3 = Theme.SurfaceAlt,
